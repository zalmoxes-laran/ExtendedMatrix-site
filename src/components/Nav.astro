---
import logoMark from '../assets/logo_mark.svg';
const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav class="em-nav">
  <div class="em-nav__inner">
    <a href={`${B}/`} class="em-nav__brand" aria-label="Extended Matrix home">
      <img src={logoMark.src} alt="" width="20" height="34" class="em-nav__mark" />
      <span class="em-nav__wordmark">
        Extended<span class="em-nav__wordmark-emph">Matrix</span>
      </span>
    </a>

    <button
      type="button"
      class="em-nav__burger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="em-nav-menu"
      data-em-burger
    >
      <span class="em-nav__burger-bar"></span>
      <span class="em-nav__burger-bar"></span>
      <span class="em-nav__burger-bar"></span>
    </button>

    <ul id="em-nav-menu" class="em-nav__links" data-em-menu>
      <li><a href={`${B}/start`}>Start</a></li>
      <li><a href={`${B}/download`}>Download</a></li>
      <li><a href={`${B}/projects`}>Projects</a></li>
      <li><a href={`${B}/news`}>News</a></li>
      <li><a href={`${B}/events`}>Events</a></li>
      <li><a href={`${B}/community`}>Community</a></li>
      <li><a href="https://docs.extendedmatrix.org" target="_blank" rel="noopener">Docs</a></li>
      <li><a href="http://dev.extendedmatrix.org/dev-projects/" target="_blank" rel="noopener noreferrer">Developers</a></li>
      <li>
        <a href="https://github.com/topics/extended-matrix" target="_blank" rel="noopener" class="em-nav__cta">
          GitHub
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const burger = document.querySelector<HTMLButtonElement>('[data-em-burger]');
  const menu = document.querySelector<HTMLUListElement>('[data-em-menu]');
  if (burger && menu) {
    const close = () => {
      burger.setAttribute('aria-expanded', 'false');
      menu.classList.remove('is-open');
      document.body.classList.remove('em-nav-locked');
    };
    burger.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      if (open) {
        close();
      } else {
        burger.setAttribute('aria-expanded', 'true');
        menu.classList.add('is-open');
        document.body.classList.add('em-nav-locked');
      }
    });
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }
</script>

<style is:global>
  body.em-nav-locked { overflow: hidden; }
</style>

<style>
  .em-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--em-bg);
    border-bottom: 1px solid var(--em-border);
  }
  .em-nav__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .em-nav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--em-navy);
  }
  .em-nav__brand:hover { color: var(--em-navy); text-decoration: none; }
  .em-nav__mark { display: block; }
  .em-nav__wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    letter-spacing: -0.01em;
    color: var(--em-navy);
  }
  .em-nav__wordmark-emph {
    font-weight: 400;
  }

  .em-nav__burger {
    display: none;
    background: transparent;
    border: 0;
    padding: 10px;
    margin-right: -10px;
    cursor: pointer;
    width: 44px;
    height: 44px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
  }
  .em-nav__burger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--em-navy);
    border-radius: 2px;
    transition: transform 0.2s var(--ease), opacity 0.2s var(--ease);
  }
  .em-nav__burger[aria-expanded="true"] .em-nav__burger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .em-nav__burger[aria-expanded="true"] .em-nav__burger-bar:nth-child(2) {
    opacity: 0;
  }
  .em-nav__burger[aria-expanded="true"] .em-nav__burger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .em-nav__links {
    display: flex;
    gap: 28px;
    list-style: none;
    align-items: center;
    margin: 0;
    padding: 0;
  }
  .em-nav__links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--em-text-muted);
  }
  .em-nav__links a:hover { color: var(--em-navy); text-decoration: none; }
  .em-nav__cta {
    background: var(--em-navy);
    color: var(--em-bg) !important;
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    font-weight: 600;
  }
  .em-nav__cta:hover {
    background: var(--em-gold);
    color: var(--em-bg) !important;
  }

  @media (max-width: 768px) {
    .em-nav__burger { display: inline-flex; }
    .em-nav__links {
      position: fixed;
      top: 64px;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--em-navy);
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 8px 0 32px;
      transform: translateX(100%);
      transition: transform 0.25s var(--ease);
      overflow-y: auto;
    }
    .em-nav__links.is-open { transform: translateX(0); }
    .em-nav__links li { width: 100%; }
    .em-nav__links a {
      display: block;
      width: 100%;
      padding: 16px 24px;
      font-size: 17px;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.9);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .em-nav__links a:hover {
      color: var(--em-gold);
      background: rgba(255, 255, 255, 0.04);
    }
    .em-nav__cta {
      background: transparent;
      color: var(--em-gold) !important;
      border: 0;
      padding: 16px 24px;
      border-radius: 0;
    }
    .em-nav__cta:hover {
      background: rgba(255, 255, 255, 0.04);
      color: var(--em-gold) !important;
    }
  }
</style>
