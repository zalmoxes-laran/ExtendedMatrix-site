---
import logoMark from '../assets/logo_mark.svg';
const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav class="em-nav">
  <div class="em-nav__inner">
    <a href={`${B}/`} class="em-nav__brand" aria-label="Extended Matrix home">
      <img src={logoMark.src} alt="" width="20" height="34" class="em-nav__mark" />
      <span class="em-nav__wordmark">
        Extended<span class="em-nav__wordmark-emph">Matrix</span>
      </span>
    </a>

    <button
      type="button"
      class="em-nav__burger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="em-nav-menu"
      data-em-burger
    >
      <span class="em-nav__burger-bar"></span>
      <span class="em-nav__burger-bar"></span>
      <span class="em-nav__burger-bar"></span>
    </button>

    <ul id="em-nav-menu" class="em-nav__links" data-em-menu>
      <li><a href={`${B}/start`}>Start</a></li>
      <li><a href={`${B}/download`}>Download</a></li>
      <li><a href={`${B}/projects`}>Projects</a></li>
      <li><a href={`${B}/publications`}>Publications</a></li>
      <li><a href={`${B}/events`}>Events</a></li>
      <li><a href={`${B}/community`}>Community</a></li>
      <li><a href="https://docs.extendedmatrix.org" target="_blank" rel="noopener">Docs</a></li>
      <li><a href="https://dev.extendedmatrix.org/" target="_blank" rel="noopener noreferrer">Developers</a></li>
      <li class="em-nav__icons">
        <a href="https://github.com/topics/extended-matrix"
           target="_blank" rel="noopener"
           class="em-nav__icon"
           aria-label="Extended Matrix on GitHub"
           title="GitHub">
          <!--
            GitHub mark. Inline SVG so we don't ship an icon font and so
            the colour follows currentColor (hovers cleanly to gold).
          -->
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.4.5 0 5.9 0 12.5c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.4-1.3-5.4-5.9 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.3 3 .1 3.3.8.9 1.3 2 1.3 3.2 0 4.6-2.7 5.6-5.4 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.8-1.6 8.2-6.2 8.2-11.4C24 5.9 18.6.5 12 .5z"/>
          </svg>
          <span class="em-nav__icon-label">GitHub</span>
        </a>
        <a href="https://t.me/UserGroupEM"
           target="_blank" rel="noopener"
           class="em-nav__icon"
           aria-label="Extended Matrix on Telegram"
           title="Telegram">
          <!--
            Telegram brand mark (Simple Icons path). The previous
            paper-plane-only path occupied only ~50% of its 24×24
            viewBox, making the icon look ~25% smaller than GitHub's
            octocat next to it. This filled-circle variant fills the
            same viewBox so the two icons sit at matching visual
            weight.
          -->
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0Zm4.962 7.224c.1-.002.321.023.466.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212-.07-.062-.174-.041-.249-.024-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.009-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
          <span class="em-nav__icon-label">Telegram</span>
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const burger = document.querySelector<HTMLButtonElement>('[data-em-burger]');
  const menu = document.querySelector<HTMLUListElement>('[data-em-menu]');
  if (burger && menu) {
    const close = () => {
      burger.setAttribute('aria-expanded', 'false');
      menu.classList.remove('is-open');
      document.body.classList.remove('em-nav-locked');
    };
    burger.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      if (open) {
        close();
      } else {
        burger.setAttribute('aria-expanded', 'true');
        menu.classList.add('is-open');
        document.body.classList.add('em-nav-locked');
      }
    });
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }
</script>

<style is:global>
  body.em-nav-locked { overflow: hidden; }
</style>

<style>
  .em-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--em-bg);
    border-bottom: 1px solid var(--em-border);
  }
  .em-nav__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .em-nav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--em-navy);
  }
  .em-nav__brand:hover { color: var(--em-navy); text-decoration: none; }
  .em-nav__mark { display: block; }
  .em-nav__wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    letter-spacing: -0.01em;
    color: var(--em-navy);
  }
  .em-nav__wordmark-emph {
    font-weight: 400;
  }

  .em-nav__burger {
    display: none;
    background: transparent;
    border: 0;
    padding: 10px;
    margin-right: -10px;
    cursor: pointer;
    width: 44px;
    height: 44px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
  }
  .em-nav__burger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--em-navy);
    border-radius: 2px;
    transition: transform 0.2s var(--ease), opacity 0.2s var(--ease);
  }
  .em-nav__burger[aria-expanded="true"] .em-nav__burger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .em-nav__burger[aria-expanded="true"] .em-nav__burger-bar:nth-child(2) {
    opacity: 0;
  }
  .em-nav__burger[aria-expanded="true"] .em-nav__burger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .em-nav__links {
    display: flex;
    gap: 28px;
    list-style: none;
    align-items: center;
    margin: 0;
    padding: 0;
  }
  .em-nav__links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--em-text-muted);
  }
  .em-nav__links a:hover { color: var(--em-navy); text-decoration: none; }
  /*
   * Icon group at the end of the nav — GitHub + Telegram. On desktop
   * these render as 32×32 icon buttons with the visible text hidden
   * (the label is preserved for screen-readers and shown inline on
   * mobile so the burger menu still reads naturally).
   */
  .em-nav__icons {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-left: 4px;
  }
  .em-nav__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    color: var(--em-text-muted);
    transition: color 0.15s var(--ease), background 0.15s var(--ease);
  }
  .em-nav__icon:hover {
    color: var(--em-gold);
    background: var(--em-gold-tint);
    text-decoration: none;
  }
  .em-nav__icon svg { display: block; }
  .em-nav__icon-label {
    /*
     * Visually hidden on desktop. Screen readers still announce it,
     * and the mobile burger menu overrides this to show the labels
     * inline next to the icons (see media query below).
     */
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 768px) {
    .em-nav__burger { display: inline-flex; }
    .em-nav__links {
      position: fixed;
      top: 64px;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--em-navy);
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 8px 0 32px;
      transform: translateX(100%);
      transition: transform 0.25s var(--ease);
      overflow-y: auto;
    }
    .em-nav__links.is-open { transform: translateX(0); }
    .em-nav__links li { width: 100%; }
    .em-nav__links a {
      display: block;
      width: 100%;
      padding: 16px 24px;
      font-size: 17px;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.9);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .em-nav__links a:hover {
      color: var(--em-gold);
      background: rgba(255, 255, 255, 0.04);
    }
    /*
     * Mobile burger: the icon group becomes a row of full-width text
     * links again (icon + label side-by-side) so it reads naturally
     * inside the slide-in menu.
     */
    .em-nav__icons {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      width: 100%;
      margin-left: 0;
    }
    .em-nav__icon {
      width: 100%;
      height: auto;
      justify-content: flex-start;
      gap: 12px;
      padding: 16px 24px;
      border-radius: 0;
      font-size: 17px;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.9);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .em-nav__icon:hover {
      background: rgba(255, 255, 255, 0.04);
      color: var(--em-gold);
    }
    .em-nav__icon-label {
      /* unhide on mobile — show inline as a normal label */
      position: static;
      width: auto; height: auto;
      padding: 0; margin: 0;
      overflow: visible;
      clip: auto;
      white-space: normal;
    }
  }
</style>
