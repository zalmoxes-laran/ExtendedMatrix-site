---
const year = new Date().getFullYear();
const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="em-footer">
  <div class="em-footer__inner">
    <div>
      <div class="em-footer__brand">
        Extended<span class="em-footer__brand-emph">Matrix</span>
      </div>
      <p class="em-footer__author">
        E. Demetrescu — CNR-ISPC, Rome — © {year}
      </p>
      <p class="em-footer__legal">
        Site content licensed
        <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener">CC BY-NC 4.0</a>
        · Code under GPL-3.0 unless noted ·
        <a href={`${B}/privacy`}>Privacy</a> ·
        <a href={`${B}/privacy#cookies`}>Cookies</a>
      </p>
    </div>
    <div class="em-footer__links">
      <a href={`${B}/about`}>About</a>
      <a href={`${B}/team`}>Team</a>
      <a href={`${B}/tools`}>Tools</a>
      <a href={`${B}/versions`}>Versions</a>
      <a href={`${B}/cite`}>Cite</a>
      <a href={`${B}/news`}>News</a>
      <a href={`${B}/events`}>Events</a>
      <a href="https://docs.extendedmatrix.org" target="_blank" rel="noopener">Docs</a>
      <a href="https://github.com/topics/extendedmatrix" target="_blank" rel="noopener">GitHub</a>
      <a href="https://zenodo.org/communities/extendedmatrix" target="_blank" rel="noopener">Zenodo</a>
      <a href="https://t.me/UserGroupEM" target="_blank" rel="noopener">Telegram</a>
    </div>
  </div>
</footer>

<style>
  .em-footer {
    background: var(--em-navy);
    color: var(--em-bg);
    padding: 40px 0;
    margin-top: 80px;
  }
  .em-footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
  }
  .em-footer__brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    color: var(--em-bg);
  }
  .em-footer__brand-emph { color: var(--em-gold); font-weight: 400; }
  .em-footer__author {
    font-size: 13px;
    margin-top: 4px;
    color: rgba(255, 255, 255, 0.7);
  }
  .em-footer__legal {
    font-size: 12px;
    margin-top: 6px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
  }
  .em-footer__legal a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.3);
  }
  .em-footer__legal a:hover {
    color: var(--em-gold);
    text-decoration-color: var(--em-gold);
  }
  .em-footer__links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .em-footer__links a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
  }
  .em-footer__links a:hover {
    color: var(--em-gold);
    text-decoration: none;
  }
</style>
