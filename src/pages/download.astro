---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const versions = (await getCollection('versions'))
  .sort((a, b) => b.data.order - a.data.order);

// Preferred — the version we want new projects to start from. Driven by
// the `is_preferred: true` flag in the version frontmatter, with a
// graceful fallback to the most recent LTS / stable.
const preferred = versions.find((v) => v.data.is_preferred)
  ?? versions.find((v) => v.data.status === 'lts')
  ?? versions.find((v) => v.data.status === 'stable');

// Legacy LTS — a still-supported LTS line that is no longer preferred
// for new projects (e.g. 1.4 once 1.5 takes over). May be undefined if
// only a single LTS line exists.
const legacyLts = versions.find(
  (v) => v.data.status === 'lts' && v.id !== preferred?.id,
);

// Active development line — the next iteration after the preferred LTS.
const development = versions.find((v) => v.data.status === 'development');

const tools = (await getCollection('tools'))
  .sort((a, b) => a.data.order - b.data.order);

const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Download"
  description="Download Extended Matrix — the formal language palette for yEd, the EM Tools Blender add-on, the s3dgraphy library and the rest of the framework. Pick the version that matches your project."
>
  <section class="dl">
    <div class="container">
      <span class="tag">Download</span>
      <h1>Get Extended Matrix.</h1>
      <p class="dl__sub">
        Two LTS lines run in parallel — the <strong>preferred</strong>
        line for new projects, and an outgoing LTS that stays supported
        so legacy projects can finish on their original combination of
        Blender + EM. The <strong>development</strong> line is where the
        next iteration is taking shape.
      </p>

      <!-- ── Quick chooser ──────────────────────────────────────── -->
      <div class="chooser">
        {preferred && (
          <a class="chooser__card chooser__card--preferred" href={`${B}/versions/${preferred.id.replace(/\.md$/, '')}/`}>
            <div class="chooser__badge chooser__badge--preferred">Start here · LTS</div>
            <h2>EM {preferred.data.version}</h2>
            <p>{preferred.data.summary}</p>
            <ul class="chooser__meta">
              <li><strong>Blender:</strong> {preferred.data.blenderLts ?? preferred.data.blenderMin}{preferred.data.blenderLts ? ' LTS' : '+'}</li>
              <li><strong>yEd:</strong> {preferred.data.yedRequirement}</li>
              {preferred.data.eolDate && <li><strong>Supported until:</strong> {preferred.data.eolDate.getFullYear()}</li>}
            </ul>
            <span class="chooser__cta">Open the {preferred.data.version} page →</span>
          </a>
        )}

        {legacyLts && (
          <a class="chooser__card chooser__card--legacy" href={`${B}/versions/${legacyLts.id.replace(/\.md$/, '')}/`}>
            <div class="chooser__badge chooser__badge--legacy">Legacy · LTS</div>
            <h2>EM {legacyLts.data.version}</h2>
            <p>{legacyLts.data.summary}</p>
            <ul class="chooser__meta">
              <li><strong>Blender:</strong> {legacyLts.data.blenderLts ?? legacyLts.data.blenderMin} LTS</li>
              <li><strong>yEd:</strong> {legacyLts.data.yedRequirement}</li>
              {legacyLts.data.eolDate && <li><strong>Supported until:</strong> {legacyLts.data.eolDate.getFullYear()}</li>}
            </ul>
            <span class="chooser__cta">Open the {legacyLts.data.version} page →</span>
          </a>
        )}
      </div>

      {/*
        ── Look-ahead strip ──────────────────────────────────────
        Compact card for the active development line (1.6+). Visually
        distinct from the two LTS cards above: smaller, horizontal,
        with a "rocket leaving the EM hourglass" mark to signal
        leading-edge work. Links out to the dev tracker for details.
      */}
      {development && (
        <a
          class="dev-strip"
          href={`${B}/versions/${development.id.replace(/\.md$/, '')}/`}
        >
          {/* SVG: a small rocket lifting diagonally out of the EM
              hourglass mark. Composed in EM palette (navy + gold).
              Inspired by the EM logo (src/assets/logo_mark.svg) —
              the hourglass silhouette is rendered faintly as a
              backdrop and the rocket exits its top funnel. */}
          <svg class="dev-strip__rocket" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <g class="dev-strip__hg" opacity="0.22">
              <rect x="22" y="40" width="20" height="2.2" fill="var(--em-navy)" />
              <path d="M 24 42 L 40 42 L 32 56 Z" fill="var(--em-navy)" />
              <path d="M 32 56 L 24 70 L 40 70 Z" fill="var(--em-navy)" />
              <rect x="22" y="69.8" width="20" height="2.2" fill="var(--em-navy)" />
            </g>
            <g class="dev-strip__r" transform="translate(35 50) rotate(-40)">
              <circle cx="-4" cy="0" r="2" fill="var(--em-gold)" opacity="0.55" />
              <circle cx="-10" cy="0" r="1.6" fill="var(--em-gold)" opacity="0.38" />
              <circle cx="-16" cy="0" r="1.2" fill="var(--em-gold)" opacity="0.22" />
              <circle cx="-22" cy="0" r="0.8" fill="var(--em-gold)" opacity="0.12" />
              <path d="M 4 -5 L 0 -9 L 0 -1 Z" fill="var(--em-navy)" />
              <path d="M 4 5 L 0 9 L 0 1 Z" fill="var(--em-navy)" />
              <rect x="4" y="-5" width="22" height="10" rx="2" fill="var(--em-navy)" />
              <circle cx="13" cy="0" r="2.5" fill="var(--em-gold-tint)" stroke="var(--em-gold)" stroke-width="1" />
              <path d="M 26 -5 L 36 0 L 26 5 Z" fill="var(--em-gold)" />
            </g>
          </svg>
          <div class="dev-strip__body">
            <div class="dev-strip__head">
              <span class="dev-strip__title">EM {development.data.version} · in development</span>
              <span class="dev-strip__arrow">→</span>
            </div>
            <p class="dev-strip__sub">
              Look ahead at upcoming features on the EM development
              tracker.
            </p>
          </div>
        </a>
      )}

      <p class="dl__all">
        Looking for an older release? See <a href={`${B}/versions/`}>all versions →</a>
      </p>

      <!-- ── Tools strip ────────────────────────────────────────── -->
      <section class="dltools">
        <h2>Individual tools</h2>
        <p class="dltools__sub">
          The framework is modular — each component has its own repository,
          docs and download page.
        </p>
        <div class="dltools__grid">
          {tools.map((t) => (
            <a class="dltools__card" href={`${B}/tools/${t.id.replace(/\.md$/, '')}/`}>
              <div class="dltools__name">{t.data.name}</div>
              <div class="dltools__role">{t.data.role}</div>
              <p class="dltools__desc">{t.data.summary}</p>
              <div class="dltools__foot">
                <span class="dltools__lic">{t.data.licence}</span>
                <span class="dltools__open">Open →</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .dl { padding: 80px 0 60px; }
  .dl h1 { margin: 14px 0 18px; }
  .dl__sub { color: var(--em-text-muted); max-width: 720px; font-size: 17px; margin-bottom: 48px; }

  .chooser {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }
  .chooser__card {
    display: block;
    border: 1px solid var(--em-border);
    border-radius: var(--radius-md);
    padding: 28px 28px 24px;
    background: var(--em-bg);
    color: var(--em-text);
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .chooser__card:hover {
    border-color: var(--em-gold);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 4px 18px rgba(26,40,69,0.08);
  }
  .chooser__card--preferred {
    border-left: 4px solid var(--em-gold);
    /* Subtle gold accent so the preferred line is unambiguous without
       overpowering the legacy card. */
    box-shadow: 0 0 0 1px var(--em-gold-tint) inset;
  }
  .chooser__card--preferred:hover {
    /* Compose the inset accent with the regular hover lift. */
    box-shadow:
      0 0 0 1px var(--em-gold-tint) inset,
      0 4px 18px rgba(26,40,69,0.08);
  }
  .chooser__card--legacy { border-left: 4px solid #aaa; }
  .chooser__badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 2px;
    margin-bottom: 12px;
  }
  .chooser__badge--preferred {
    color: var(--em-gold);
    background: var(--em-gold-tint);
  }
  .chooser__badge--legacy {
    color: #555;
    background: #eee;
  }
  .chooser__card h2 { font-size: 28px; margin: 4px 0 8px; }
  .chooser__card p { color: var(--em-text); margin-bottom: 14px; line-height: 1.6; }
  .chooser__meta {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    font-size: 13px;
    color: var(--em-text-muted);
    display: grid;
    gap: 4px;
  }
  .chooser__cta {
    color: var(--em-gold);
    font-weight: 600;
    font-size: 14px;
  }

  /* ── Look-ahead strip (1.6 dev) ───────────────────────────── */
  .dev-strip {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 22px;
    padding: 14px 22px 14px 16px;
    border: 1px solid var(--em-border);
    border-radius: var(--radius-md);
    /* Aerial gradient — navy hint on the left fading to a warm gold
       wash on the right, kept light so the card reads as "preview"
       rather than a peer of the LTS cards above. */
    background:
      linear-gradient(
        90deg,
        var(--em-navy-tint) 0%,
        var(--em-bg) 45%,
        var(--em-gold-tint) 100%
      );
    color: var(--em-text);
    text-decoration: none;
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
  .dev-strip:hover {
    border-color: var(--em-gold);
    text-decoration: none;
    box-shadow: 0 4px 18px rgba(26,40,69,0.08);
  }
  .dev-strip__rocket {
    flex: 0 0 auto;
    width: 64px;
    height: 64px;
    transition: transform 0.35s var(--ease);
  }
  /* On hover, the rocket lifts diagonally — the takeoff micro-animation. */
  .dev-strip:hover .dev-strip__rocket {
    transform: translate(4px, -4px);
  }
  .dev-strip__body { flex: 1 1 auto; min-width: 0; }
  .dev-strip__head {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .dev-strip__title {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--em-navy);
    font-size: 17px;
  }
  .dev-strip__arrow {
    color: var(--em-gold);
    font-weight: 700;
    transition: transform 0.2s var(--ease);
  }
  .dev-strip:hover .dev-strip__arrow {
    transform: translateX(3px);
  }
  .dev-strip__sub {
    margin: 4px 0 0;
    font-size: 13px;
    color: var(--em-text-muted);
    line-height: 1.5;
  }

  .dl__all {
    margin: 32px 0 0;
    color: var(--em-text-muted);
    font-size: 14px;
  }
  .dl__all a { color: var(--em-gold); font-weight: 600; }

  .dltools { margin-top: 80px; }
  .dltools h2 { font-size: 28px; }
  .dltools__sub { color: var(--em-text-muted); max-width: 600px; margin: 8px 0 28px; }
  .dltools__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .dltools__card {
    display: block;
    padding: 22px 24px;
    border: 1px solid var(--em-border);
    border-radius: var(--radius-md);
    background: var(--em-bg);
    color: var(--em-text);
    transition: border-color 0.2s var(--ease);
  }
  .dltools__card:hover { border-color: var(--em-gold); text-decoration: none; }
  .dltools__name {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--em-navy);
    font-size: 17px;
  }
  .dltools__role {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--em-gold);
    margin: 4px 0 10px;
  }
  .dltools__desc {
    font-size: 13px;
    color: var(--em-text);
    line-height: 1.55;
    margin: 0 0 14px;
  }
  .dltools__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--em-text-muted);
  }
  .dltools__open { color: var(--em-gold); font-weight: 600; }

  @media (max-width: 800px) {
    .chooser { grid-template-columns: 1fr; }
    .dltools__grid { grid-template-columns: 1fr; }
    .dev-strip { padding: 12px 16px 12px 12px; }
    .dev-strip__rocket { width: 52px; height: 52px; }
  }
</style>
