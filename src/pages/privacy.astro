---
import BaseLayout from '../layouts/BaseLayout.astro';
const B = import.meta.env.BASE_URL.replace(/\/$/, '');

// Last review of this notice. Bump when the substance changes.
const lastReviewed = '2026-05-10';
---

<BaseLayout
  title="Privacy notice"
  description="Privacy notice for extendedmatrix.org — what (little) data is processed when you visit, the third-party embeds we use, your rights under the GDPR, and how to contact us."
>
  <section class="privacy">
    <div class="container">
      <span class="tag">Privacy</span>
      <h1>Privacy notice.</h1>
      <p class="privacy__lede">
        This notice describes how <strong>extendedmatrix.org</strong>
        handles personal data under the EU General Data Protection
        Regulation (Regulation (EU) 2016/679 — GDPR). The site is a
        static, public information service for the Extended Matrix
        research project; we keep data processing to the minimum
        compatible with running it.
      </p>

      <p class="privacy__meta">
        Last reviewed: <time datetime={lastReviewed}>{lastReviewed}</time>.
      </p>

      <!-- ── Data controller ─────────────────────────────────── -->
      <section class="block">
        <h2>1 · Data controller</h2>
        <p>
          The data controller for this website is
          <strong>Emanuel Demetrescu</strong> (personal capacity).
          Contact:
          <a href="mailto:emanuel.demetrescu@cnr.it">emanuel.demetrescu@cnr.it</a>.
        </p>
        <p class="privacy__note">
          <em>Affiliation: Consiglio Nazionale delle Ricerche, Istituto di
          Scienze del Patrimonio Culturale (CNR-ISPC). The institutional
          affiliation is provided for context; this site is operated in
          personal research capacity, not as an institutional CNR-ISPC
          service.</em>
        </p>
        <p>
          The Heriverse 3D viewer embedded on the home page (see §3) is
          served from a CNR-ISPC server (<code>strativerse-test.ispc.cnr.it</code>).
          Any processing performed through that embed sits under
          CNR-ISPC's responsibility, with the CNR Data Protection Officer
          (<a href="mailto:rpd@cnr.it">rpd@cnr.it</a>) as the point of
          contact for that service.
        </p>
      </section>

      <!-- ── What we collect on this site ────────────────────── -->
      <section class="block">
        <h2>2 · What this website collects</h2>
        <p>
          The site is statically generated and served via
          <strong>GitHub Pages</strong>. It does <strong>not</strong> set
          first-party cookies, does <strong>not</strong> use any
          client-side storage (<code>localStorage</code>, <code>sessionStorage</code>),
          and does not log visitors beyond what GitHub does on its own
          infrastructure.
        </p>
        <p>
          Aggregate, cookieless visit measurement is provided by
          <strong>GoatCounter</strong> — see §4 for the details and
          the legal basis.
        </p>
        <p>
          GitHub may log technical information such as the IP address
          of incoming requests and the user-agent string, for the sole
          purpose of operating its CDN and detecting abuse. This is
          covered by GitHub's own
          <a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement" target="_blank" rel="noopener">privacy statement</a>.
        </p>
      </section>

      <!-- ── Third-party embeds ──────────────────────────────── -->
      <section class="block">
        <h2>3 · Third-party content embedded on this site</h2>
        <p>
          A small number of pages embed content served by third
          parties. When you load such a page (and, for the Heriverse
          embed, when you explicitly click to load it), your browser
          establishes a direct connection to those services and they
          may, in turn, process technical data (IP address, user agent,
          time of access) under their own privacy policies.
        </p>
        <ul class="privacy__list">
          <li>
            <strong>Heriverse (strativerse-test.ispc.cnr.it)</strong>
            — the home page features an interactive 3D viewer
            (<a href={`${B}/tools/heriverse/`}>Heriverse</a>) hosted
            on a CNR-ISPC server. To respect your privacy, this iframe
            <strong>does not load until you explicitly click "Load
            Heriverse"</strong> on the page. When you click, a
            connection is opened to
            <code>strativerse-test.ispc.cnr.it</code> and a session
            cookie (<code>connect.sid</code>, HttpOnly, no cross-site
            tracking) may be set on that domain. The processing of any
            data through that iframe is governed by CNR-ISPC's privacy
            policy.
          </li>
          <li>
            <strong>YouTube (youtube-nocookie.com)</strong> — used on
            the <a href={`${B}/events`}>Events</a> pages to embed
            recordings of EM Conference, EM Bazaar and related talks.
            We use the <em>privacy-enhanced</em>
            <code>youtube-nocookie.com</code> domain, which defers the
            placement of persistent identifiers until you actually
            press Play. See Google's
            <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">privacy policy</a>.
          </li>
          <li>
            <strong>Zenodo (zenodo.org)</strong> — when you click a
            DOI or community link, you leave this site and continue on
            <code>zenodo.org</code>, operated by CERN. See the
            <a href="https://about.zenodo.org/policies/" target="_blank" rel="noopener">Zenodo policies</a>.
          </li>
          <li>
            <strong>GitHub (github.com / topics)</strong> — repository
            and topic pages opened from the navigation, footer, and
            tools pages.
          </li>
          <li>
            <strong>Telegram (t.me)</strong> — an outbound link to the
            community chat, no embed; subject to
            <a href="https://telegram.org/privacy" target="_blank" rel="noopener">Telegram's privacy policy</a>
            once you join.
          </li>
        </ul>
        <p>
          We do <strong>not</strong> embed advertising tags,
          social-media widgets or fingerprinting scripts.
        </p>
      </section>

      <!-- ── Analytics ───────────────────────────────────────── -->
      <section class="block">
        <h2>4 · Analytics</h2>
        <p>
          This site uses <strong>GoatCounter</strong> (operated by
          Martin Tournoij, EU-hosted in the Netherlands) to measure
          aggregate visits, page views and download counts. GoatCounter
          is <strong>cookieless and privacy-friendly</strong>: it does
          <strong>not</strong> set persistent cookies, does not track
          users across sites, and does not collect personal data.
        </p>
        <p>
          The visit measurement is based on a daily-rotating, anonymous
          hash derived from a salted combination of IP address and user
          agent. By design, this identifier is reset every 24 hours,
          making cross-day or cross-visit tracking impossible.
        </p>
        <p>
          Aggregated data (monthly visits, top pages, download counts)
          is retained as long as the analytics service operates; no
          per-visit raw data with identifying information is stored.
        </p>
        <p>
          <strong>Legal basis:</strong> legitimate interest
          (Art. 6(1)(f) GDPR — research project audience measurement
          and dissemination metrics). No consent banner is required
          because no personal data is processed. See the
          <a href="https://www.goatcounter.com/help/privacy" target="_blank" rel="noopener">GoatCounter privacy policy</a>
          for technical details.
        </p>
      </section>

      <!-- ── Web fonts ───────────────────────────────────────── -->
      <section class="block">
        <h2>5 · Web fonts</h2>
        <p>
          Web fonts (Inter, Manrope) are <strong>self-hosted</strong>
          on this site — they are served directly from the same domain
          as the rest of the content. <strong>No data is transferred to
          third-party font services</strong> (Google Fonts, etc.) when
          you visit any page.
        </p>
      </section>

      <!-- ── Cookies ─────────────────────────────────────────── -->
      <section class="block" id="cookies">
        <h2>6 · Cookies</h2>
        <p>
          This site does not set any first-party cookies on its own.
        </p>
        <p>
          The Heriverse iframe (<code>strativerse-test.ispc.cnr.it</code>),
          if you choose to load it, may set a session cookie called
          <code>connect.sid</code> on the CNR-ISPC domain. This cookie
          is technical (session management for the 3D viewer), is
          <code>HttpOnly</code>, does not perform cross-site tracking,
          and is automatically discarded when you close the browser.
          We have no access to or control over this cookie.
        </p>
        <p>
          GoatCounter is cookieless and does not set any cookies.
        </p>
      </section>

      <!-- ── Forms / contact ──────────────────────────────── -->
      <section class="block">
        <h2>7 · Forms and contact</h2>
        <p>
          The site has no contact form. If you choose to write to the
          email address listed above, your message and the associated
          email metadata will be processed on the legal basis of
          <em>consent</em> (Art. 6(1)(a) GDPR) and/or <em>legitimate
          interest</em> (Art. 6(1)(f) GDPR) for the purpose of
          replying. Messages are retained no longer than necessary to
          handle the conversation.
        </p>
      </section>

      <!-- ── Legal bases ─────────────────────────────── -->
      <section class="block">
        <h2>8 · Legal bases for processing</h2>
        <p>
          To the extent any personal data is processed in the context
          of this website, the legal bases are:
        </p>
        <ul class="privacy__list">
          <li><strong>Art. 6(1)(f) GDPR</strong> — legitimate interest in operating, securing and analysing the site (infrastructure logs at the GitHub Pages level; aggregate, cookieless audience measurement via GoatCounter).</li>
          <li><strong>Art. 6(1)(a) GDPR</strong> — explicit consent: when you click "Load Heriverse" to load the third-party 3D viewer, or when you press Play on an embedded YouTube video.</li>
        </ul>
      </section>

      <!-- ── Your rights ────────────────────────────────── -->
      <section class="block">
        <h2>9 · Your rights</h2>
        <p>
          Under Articles 15 to 22 of the GDPR, you have the right to
          access, rectify, erase or restrict processing of your
          personal data, to object to processing, and to data
          portability where applicable. You also have the right to
          lodge a complaint with the
          <a href="https://www.garanteprivacy.it/" target="_blank" rel="noopener">Italian Data Protection Authority (Garante per la protezione dei dati personali)</a>.
        </p>
        <p>
          To exercise these rights with respect to this website, write
          to <a href="mailto:emanuel.demetrescu@cnr.it">emanuel.demetrescu@cnr.it</a>.
          For matters specific to the Heriverse embed served from
          <code>strativerse-test.ispc.cnr.it</code>, the CNR Data
          Protection Officer is the point of contact:
          <a href="mailto:rpd@cnr.it">rpd@cnr.it</a>.
        </p>
      </section>

      <!-- ── Changes ─────────────────────────────────── -->
      <section class="block">
        <h2>10 · Changes to this notice</h2>
        <p>
          This notice may be updated when the site changes (new
          embedded services, new functionality, etc.). The "last
          reviewed" date at the top of this page reflects the latest
          substantive update. The full revision history is available
          in the
          <a href="https://github.com/zalmoxes-laran/ExtendedMatrix-site/commits/main/src/pages/privacy.astro" target="_blank" rel="noopener">site repository</a>.
        </p>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .privacy { padding: 80px 0 60px; }
  .privacy h1 { margin: 14px 0 18px; }
  .privacy__lede {
    max-width: 760px;
    color: var(--em-text);
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 8px;
  }
  .privacy__meta {
    color: var(--em-text-muted);
    font-size: 13px;
    margin-bottom: 40px;
  }
  .privacy__note {
    font-size: 14px;
    color: var(--em-text-muted);
    border-left: 2px solid var(--em-gold);
    padding-left: 12px;
    margin: 8px 0 16px;
  }
  .privacy .block { margin-bottom: 36px; max-width: 760px; }
  .privacy h2 { font-size: 19px; margin: 0 0 12px; color: var(--em-navy); }
  .privacy p { line-height: 1.7; margin-bottom: 12px; }
  .privacy a { color: var(--em-gold); }
  .privacy code {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--em-navy-tint);
    color: var(--em-navy);
    padding: 1px 6px;
    border-radius: 2px;
  }
  .privacy__list {
    list-style: disc;
    padding-left: 22px;
    margin: 8px 0 16px;
  }
  .privacy__list li {
    margin-bottom: 8px;
    line-height: 1.65;
  }
</style>
