---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((t) => ({
    params: { slug: t.id.replace(/\.md$/, '') },
    props: { tool: t },
  }));
}

const { tool } = Astro.props;
const { Content } = await render(tool);

// Find which versions ship this tool
const versions = await getCollection('versions');
const inVersions = versions
  .filter((v) => v.data.tools.some((t) => t.slug === tool.id.replace(/\.md$/, '')))
  .map((v) => {
    const ref = v.data.tools.find((t) => t.slug === tool.id.replace(/\.md$/, ''));
    return { v, ref };
  })
  .sort((a, b) => b.v.data.order - a.v.data.order);

const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={tool.data.name}
  description={tool.data.summary}
>
  <article class="tp">
    <div class="container">
      <a href={`${B}/tools/`} class="tp__back">← All tools</a>
      <div class="tp__head">
        {tool.data.icon && (
          <Image
            src={tool.data.icon}
            alt={`${tool.data.name} logo`}
            widths={[96, 192]}
            sizes="96px"
            class="tp__icon"
          />
        )}
        <div class="tp__head-text">
          <h1 class="tp__title">{tool.data.name}</h1>
          <span class={`tp__status tp__status--${tool.data.status}`}>{tool.data.status}</span>
        </div>
      </div>
      <div class="tp__role">{tool.data.role}</div>
      {tool.data.roles.length > 0 && (
        <div class="tp__roles">
          For:
          {tool.data.roles.map((r) => (
            <span class={`role-badge role-badge--${r}`}>{r}</span>
          ))}
        </div>
      )}
      <p class="tp__lede">{tool.data.summary}</p>

      <!-- ── Quick links ─────────────────────────────────────── -->
      {(() => {
        // Build the "Download latest" URL — prefer GitHub /releases/latest
        // (which redirects to the most recent tagged release), then any
        // explicit downloadUrl from the frontmatter as a fallback.
        let latestDownload: string | undefined;
        if (tool.data.repoUrl && tool.data.repoUrl.includes('github.com')) {
          latestDownload = tool.data.repoUrl.replace(/\/$/, '') + '/releases/latest';
        } else if (tool.data.downloadUrl) {
          latestDownload = tool.data.downloadUrl;
        }
        return (
          <>
            <div class="tp__links">
              {latestDownload && (
                <a href={latestDownload} target="_blank" rel="noopener" class="tp__btn">
                  ⬇ Download latest
                </a>
              )}
              {tool.data.docsUrl && <a href={tool.data.docsUrl} target="_blank" rel="noopener" class="tp__btn tp__btn--ghost">Manual ↗</a>}
              {tool.data.repoUrl && <a href={tool.data.repoUrl} target="_blank" rel="noopener" class="tp__btn tp__btn--ghost">GitHub ↗</a>}
              <span class="tp__lic">Licence: <strong>{tool.data.licence}</strong></span>
            </div>
            {inVersions.length > 0 && (
              <p class="tp__hint">
                Or pick a specific EM version below ↓
              </p>
            )}
          </>
        );
      })()}

      <!-- ── Body ────────────────────────────────────────────── -->
      <section class="tp__body">
        <Content />
      </section>

      <!-- ── Shipped in versions ─────────────────────────────── -->
      {inVersions.length > 0 && (
        <section class="tp__ships">
          <h2>Shipped in EM versions</h2>
          <p class="tp__ships-lede">
            One-click download for each combination — or click the EM version
            number to see its full compatibility matrix.
          </p>
          <table class="tp__matrix">
            <thead>
              <tr>
                <th>Download</th>
                <th>EM version</th>
                <th>Tool version</th>
                <th>Status</th>
                <th>Note</th>
              </tr>
            </thead>
            <tbody>
              {inVersions.map(({ v, ref }) => (
                <tr>
                  <td>
                    {ref?.downloadUrl
                      ? <a href={ref.downloadUrl} target="_blank" rel="noopener" class="tp__dlink">⬇ download</a>
                      : <span class="tp__nodl">—</span>}
                  </td>
                  <td><a href={`${B}/versions/${v.id.replace(/\.md$/, '')}/`}><strong>EM {v.data.version}</strong></a></td>
                  <td class="tp__ver">{ref?.version ?? '—'}</td>
                  <td>{ref?.status ?? '—'}</td>
                  <td>{ref?.note ?? ''}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .tp { padding: 60px 0 80px; }
  .tp__back { display: inline-block; font-size: 13px; color: var(--em-text-muted); margin-bottom: 16px; }
  .tp__head { display: flex; align-items: center; gap: 18px; margin-top: 12px; }
  .tp__head-text { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; }
  .tp__icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: contain;
    background: var(--em-bg);
    border: 1px solid var(--em-border);
    flex: 0 0 auto;
  }
  .tp__title { margin: 0; }
  .tp__status {
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    padding: 3px 10px; border-radius: 2px;
  }
  .tp__status--stable  { color: #2c5a2c; background: #d8ecd8; }
  .tp__status--beta    { color: var(--em-navy); background: var(--em-navy-tint); }
  .tp__status--alpha   { color: #8a5a14; background: #fae6c8; }
  .tp__status--planned { color: #555; background: #eee; }
  .tp__role {
    font-size: 13px; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--em-gold); font-weight: 600; margin: 6px 0 8px;
  }
  .tp__roles {
    font-size: 12px;
    color: var(--em-text-muted);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .tp__lede { font-size: 17px; color: var(--em-text); max-width: 720px; line-height: 1.65; margin-bottom: 28px; }

  .tp__links {
    display: flex; flex-wrap: wrap; gap: 12px; align-items: center;
    margin-bottom: 40px;
  }
  .tp__btn {
    background: var(--em-navy); color: var(--em-bg);
    padding: 10px 18px; border-radius: var(--radius-sm);
    font-weight: 600; font-size: 14px;
  }
  .tp__btn:hover { background: var(--em-gold); color: var(--em-bg); text-decoration: none; }
  .tp__btn--ghost { background: transparent; color: var(--em-navy); border: 1px solid var(--em-navy); }
  .tp__btn--ghost:hover { background: var(--em-navy); color: var(--em-bg); }
  .tp__lic { font-size: 12px; color: var(--em-text-muted); margin-left: auto; }
  .tp__hint {
    margin: -28px 0 36px;
    font-size: 13px;
    color: var(--em-text-muted);
    font-style: italic;
  }
  .tp__ships-lede { color: var(--em-text-muted); margin: 4px 0 16px; font-size: 14px; }
  .tp__dlink {
    color: var(--em-gold) !important;
    font-weight: 600;
    white-space: nowrap;
  }
  .tp__nodl { color: var(--em-text-muted); }

  .tp__body :global(h2) { margin-top: 32px; font-size: 22px; }
  .tp__body :global(h3) { margin-top: 22px; font-size: 18px; }
  .tp__body :global(p) { margin-bottom: 14px; line-height: 1.7; }
  .tp__body :global(ul), .tp__body :global(ol) { margin-bottom: 14px; padding-left: 22px; }
  .tp__body :global(pre) {
    background: var(--em-bg-warm); border: 1px solid var(--em-border);
    padding: 14px 18px; border-radius: var(--radius-md);
    overflow-x: auto; font-size: 13px;
  }
  .tp__body :global(code) {
    font-family: var(--font-mono); font-size: 13px;
    background: var(--em-navy-tint); color: var(--em-navy);
    padding: 1px 6px; border-radius: 2px;
  }
  .tp__body :global(pre code) { background: none; color: inherit; padding: 0; }

  .tp__ships { margin-top: 56px; }
  .tp__ships h2 { font-size: 22px; margin-bottom: 16px; }
  .tp__matrix { width: 100%; border-collapse: collapse; font-size: 14px; }
  .tp__matrix th, .tp__matrix td {
    text-align: left; padding: 12px 14px; border-bottom: 1px solid var(--em-border);
  }
  .tp__matrix th { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--em-gold); }
  .tp__ver { font-family: var(--font-mono); }
</style>
