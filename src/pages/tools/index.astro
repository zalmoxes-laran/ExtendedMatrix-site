---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = (await getCollection('tools'))
  .sort((a, b) => a.data.order - b.data.order);

const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Tools"
  description="The components of the Extended Matrix Framework — language palette, Blender add-on, Python library, web platform, photogrammetry pipeline."
>
  <section class="tools">
    <div class="container">
      <span class="tag">EM Framework</span>
      <h1>The tools that speak EM.</h1>
      <p class="tools__sub">
        EM is the formal language — pencil and paper would be enough. The
        <strong>EM Framework (EMF)</strong> is the digital toolset that lets
        you author, manage and publish EM at scale. Each tool below is an
        open-source component with its own repository, documentation and
        release cycle.
      </p>

      <div class="tools__filters" role="tablist">
        <a href="#" class="filter-chip" data-role="all" aria-current="true">All tools</a>
        <a href="#archaeologist" class="filter-chip" data-role="archaeologist">For archaeologists</a>
        <a href="#modeller" class="filter-chip" data-role="modeller">For 3D modellers</a>
        <a href="#developer" class="filter-chip" data-role="developer">For developers</a>
      </div>

      <ul class="grid" id="tools-grid">
        {tools.map((t) => (
          <li class="card" data-roles={t.data.roles.join(' ')}>
            <a href={`${B}/tools/${t.id.replace(/\.md$/, '')}/`}>
              <div class="card__head">
                <h2 class="card__name">{t.data.name}</h2>
                <span class={`card__status card__status--${t.data.status}`}>{t.data.status}</span>
              </div>
              <div class="card__role">{t.data.role}</div>
              <p class="card__desc">{t.data.summary}</p>
              {t.data.roles.length > 0 && (
                <div class="card__roles">
                  {t.data.roles.map((r) => (
                    <span class={`role-badge role-badge--${r}`}>{r}</span>
                  ))}
                </div>
              )}
              <div class="card__foot">
                <span class="card__lic">{t.data.licence}</span>
                <span class="card__open">Open page →</span>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <p class="tools__empty" hidden>No tools match this role yet.</p>

      <p class="tools__foot">
        Looking for a specific Blender / yEd / EM combination?
        <a href={`${B}/versions/`}>see the version-by-version compatibility matrix →</a>
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Light role filter — reacts to URL hash and to chip clicks. No deps.
  (function () {
    const chips = Array.from(document.querySelectorAll('.filter-chip'));
    const cards = Array.from(document.querySelectorAll('#tools-grid .card'));
    const empty = document.querySelector('.tools__empty');

    function apply(role) {
      let shown = 0;
      cards.forEach((c) => {
        const roles = (c.dataset.roles || '').split(' ').filter(Boolean);
        const match = role === 'all' || roles.includes(role);
        c.hidden = !match;
        if (match) shown++;
      });
      chips.forEach((ch) => ch.setAttribute('aria-current', ch.dataset.role === role ? 'true' : 'false'));
      if (empty) empty.hidden = shown > 0;
    }

    function fromHash() {
      const h = (window.location.hash || '').replace('#', '');
      apply(['archaeologist', 'modeller', 'developer'].includes(h) ? h : 'all');
    }

    chips.forEach((ch) => {
      ch.addEventListener('click', (e) => {
        e.preventDefault();
        const role = ch.dataset.role;
        if (role === 'all') {
          history.replaceState(null, '', window.location.pathname);
        } else {
          history.replaceState(null, '', '#' + role);
        }
        apply(role);
      });
    });

    fromHash();
    window.addEventListener('hashchange', fromHash);
  })();
</script>

<style>
  .tools { padding: 80px 0 60px; }
  .tools h1 { margin: 14px 0 16px; }
  .tools__sub { max-width: 720px; color: var(--em-text-muted); font-size: 17px; margin-bottom: 24px; }

  .tools__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }
  .filter-chip {
    display: inline-block;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid var(--em-border);
    border-radius: 20px;
    color: var(--em-text-muted);
    background: var(--em-bg);
    transition: all 0.15s var(--ease);
  }
  .filter-chip:hover {
    color: var(--em-navy);
    border-color: var(--em-navy);
    text-decoration: none;
  }
  .filter-chip[aria-current="true"] {
    background: var(--em-navy);
    color: var(--em-bg);
    border-color: var(--em-navy);
  }

  .tools__empty {
    text-align: center;
    color: var(--em-text-muted);
    font-style: italic;
    padding: 40px 0;
  }

  .card__roles { margin: 0 0 12px; display: flex; flex-wrap: wrap; gap: 4px; }
  .grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px;
  }
  .card {
    border: 1px solid var(--em-border); border-radius: var(--radius-md);
    background: var(--em-bg); transition: border-color 0.2s var(--ease);
  }
  .card:hover { border-color: var(--em-gold); }
  .card a { display: block; padding: 24px 26px; color: inherit; }
  .card a:hover { text-decoration: none; }
  .card__head { display: flex; justify-content: space-between; align-items: center; }
  .card__name { font-family: var(--font-display); font-size: 19px; color: var(--em-navy); margin: 0; }
  .card__status {
    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    padding: 2px 8px; border-radius: 2px;
  }
  .card__status--stable  { color: #2c5a2c; background: #d8ecd8; }
  .card__status--beta    { color: var(--em-navy); background: var(--em-navy-tint); }
  .card__status--alpha   { color: #8a5a14; background: #fae6c8; }
  .card__status--planned { color: #555; background: #eee; }
  .card__role {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--em-gold); font-weight: 600; margin: 6px 0 10px;
  }
  .card__desc { font-size: 14px; line-height: 1.6; color: var(--em-text); margin: 0 0 14px; }
  .card__foot {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 12px; font-family: var(--font-mono); color: var(--em-text-muted);
  }
  .card__open { color: var(--em-gold); font-weight: 600; }
  .tools__foot { margin-top: 48px; color: var(--em-text-muted); font-size: 14px; }
  .tools__foot a { color: var(--em-gold); font-weight: 600; }

  @media (max-width: 700px) { .grid { grid-template-columns: 1fr; } }
</style>
