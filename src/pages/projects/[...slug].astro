---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({
    params: { slug: p.id.replace(/\.md$/, '') },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
>
  <article class="proj">
    <div class="container">
      <a href={`${B}/projects/`} class="proj__back">← All projects</a>
      <span class="tag">{project.data.year ?? 'Project'}</span>
      <h1 class="proj__title">{project.data.title}</h1>

      <div class="proj__meta">
        {project.data.location && (
          <div class="proj__meta-item">
            <span class="proj__meta-label">Location</span>
            <span class="proj__meta-value">{project.data.location}</span>
          </div>
        )}
        {project.data.partners && project.data.partners.length > 0 && (
          <div class="proj__meta-item">
            <span class="proj__meta-label">Partners</span>
            <span class="proj__meta-value">{project.data.partners.join(' · ')}</span>
          </div>
        )}
        {project.data.website && (
          <div class="proj__meta-item">
            <span class="proj__meta-label">Website</span>
            <a class="proj__meta-value" href={project.data.website} target="_blank" rel="noopener">
              {project.data.website.replace(/^https?:\/\//, '')}
            </a>
          </div>
        )}
      </div>

      {project.data.cover && (
        <figure class="proj__cover">
          <Image
            src={project.data.cover}
            alt={project.data.coverAlt || project.data.title}
            widths={[480, 768, 1100]}
            sizes="(max-width: 768px) 100vw, min(1100px, 100vw)"
            loading="eager"
          />
        </figure>
      )}

      <div class="proj__body">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .proj { padding: 60px 0 80px; }
  .proj__back {
    display: inline-block;
    font-size: 13px;
    color: var(--em-text-muted);
    margin-bottom: 16px;
  }
  .proj__title { margin: 14px 0 24px; }
  .proj__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 32px 48px;
    padding: 20px 0;
    border-block: 1px solid var(--em-border);
    margin-bottom: 32px;
  }
  .proj__meta-item { display: flex; flex-direction: column; gap: 4px; }
  .proj__meta-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--em-gold);
    font-weight: 700;
  }
  .proj__meta-value {
    font-size: 14px;
    color: var(--em-text);
  }
  .proj__cover {
    margin: 0 auto 40px;
    border-radius: var(--radius-md);
    overflow: hidden;
    text-align: center;
    /* Cap at 60% of the container on desktop — most project covers
       are honest archaeological photos / renders that don't hold up
       being upscaled to the 1100px container width. The 60% cap is
       applied here at the wrapper level so the figure (including
       potential captions in the future) stays centered with the
       same aspect ratio. Mobile reverts to 100% via the media query
       below — at <=768px viewports the 60% cap would make images
       too small to read. */
    max-width: 60%;
  }
  .proj__cover img {
    max-width: 100%;
    width: auto;
    height: auto;
    display: block;
    margin: 0 auto;
  }
  .proj__body :global(h2) { margin-top: 32px; }
  .proj__body :global(p) { margin-bottom: 14px; }
  .proj__body :global(ul) { margin-bottom: 14px; padding-left: 22px; }

  /* Figure-style: a paragraph that contains only an image, optionally
     followed by a paragraph that contains only an italic caption.
     Same 60% cap as .proj__cover: most inline body images on project
     pages are figures / process screenshots / render comparisons
     that don't read well at full container width. */
  .proj__body :global(p:has(> img:only-child)) {
    margin: 28px 0 4px;
    text-align: center;
  }
  .proj__body :global(p:has(> img:only-child) img) {
    max-width: 60%;
    height: auto;
    display: block;
    margin: 0 auto;
    border-radius: var(--radius-sm);
  }

  /* Mobile breakpoint: at <=768px the 60% cap kicks in too hard
     (60% of ~360px = ~216px wide) — for phone screens revert to
     100% so figures stay legible. */
  @media (max-width: 768px) {
    .proj__cover { max-width: 100%; }
    .proj__body :global(p:has(> img:only-child) img) { max-width: 100%; }
  }
  .proj__body :global(p:has(> img:only-child) + p:has(> em:only-child)) {
    text-align: center;
    font-style: italic;
    color: var(--em-text-muted);
    font-size: 13px;
    margin-top: 0;
    margin-bottom: 28px;
  }
</style>
