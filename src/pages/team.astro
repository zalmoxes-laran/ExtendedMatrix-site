---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allTeam = (await getCollection('team'))
  .sort((a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name));

// Three sections, in render order: active maintainers, honorary
// contributors (still credited — past work that continues to shape
// the project), scientific committee (future structure — section
// appears empty for now with a "being designed" note). The
// `status` enum on the schema drives this split; the internal
// enum value remains `past` to avoid churn in the YAML data
// files — only the user-visible label changes.
const active = allTeam.filter((m) => (m.data.status ?? 'active') === 'active');
const past = allTeam.filter((m) => m.data.status === 'past');
const committee = allTeam.filter((m) => m.data.status === 'committee');

const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Team"
  description="The people behind Extended Matrix — core maintainers, honorary contributors and (future) scientific committee."
>
  <section class="team">
    <div class="container">
      <span class="tag">Team</span>
      <h1>The people behind EM.</h1>
      <p class="team__sub">
        Extended Matrix is developed by an open, voluntary research
        community. Active maintainers and contributors are listed
        first, followed by honorary contributors whose past work
        continues to shape the project. Many more people use, teach
        and extend EM in their own work — see the
        <a href={`${B}/projects`}>projects gallery</a> and the
        <a href={`${B}/about#partners`}>partners section</a>.
      </p>

      {active.length > 0 && (
        <>
          <h2 class="team__section-h">Active maintainers</h2>
          <ul class="grid">
            {active.map((m) => (
              <li class="member">
                <div class="member__avatar">
                  {m.data.avatar ? (
                    <img src={m.data.avatar.src} alt={m.data.name} loading="lazy" />
                  ) : (
                    <div class="member__avatar-empty">{m.data.name.split(' ').map(n => n[0]).join('').slice(0, 2)}</div>
                  )}
                </div>
                <div class="member__body">
                  <h3 class="member__name">{m.data.name}</h3>
                  <div class="member__role">{m.data.role}</div>
                  <div class="member__aff">{m.data.affiliation}</div>
                  {m.data.bio && <p class="member__bio">{m.data.bio}</p>}
                  <ul class="member__links">
                    {m.data.orcid && <li><a href={`https://orcid.org/${m.data.orcid}`} target="_blank" rel="noopener">ORCID</a></li>}
                    {m.data.email && <li><a href={`mailto:${m.data.email}`}>email</a></li>}
                  </ul>
                </div>
              </li>
            ))}
          </ul>
        </>
      )}

      {past.length > 0 && (
        <>
          <h2 class="team__section-h">Honorary contributors</h2>
          <p class="team__section-lede">
            Researchers and contributors whose past work continues
            to shape EM today — recognised for the role they played.
          </p>
          <ul class="grid">
            {past.map((m) => (
              <li class="member member--past">
                <div class="member__avatar">
                  {m.data.avatar ? (
                    <img src={m.data.avatar.src} alt={m.data.name} loading="lazy" />
                  ) : (
                    <div class="member__avatar-empty">{m.data.name.split(' ').map(n => n[0]).join('').slice(0, 2)}</div>
                  )}
                </div>
                <div class="member__body">
                  <h3 class="member__name">{m.data.name}</h3>
                  <div class="member__role">{m.data.role}</div>
                  <div class="member__aff">{m.data.affiliation}</div>
                  {m.data.bio && <p class="member__bio">{m.data.bio}</p>}
                  <ul class="member__links">
                    {m.data.orcid && <li><a href={`https://orcid.org/${m.data.orcid}`} target="_blank" rel="noopener">ORCID</a></li>}
                    {m.data.email && <li><a href={`mailto:${m.data.email}`}>email</a></li>}
                  </ul>
                </div>
              </li>
            ))}
          </ul>
        </>
      )}

      <h2 class="team__section-h">Scientific committee</h2>
      <p class="team__section-lede team__section-lede--placeholder">
        The scientific committee is a separate, prestige-tier
        structure being designed. It will be populated as the
        composition and membership criteria are finalised.
      </p>
      {committee.length > 0 && (
        <ul class="grid">
          {committee.map((m) => (
            <li class="member member--committee">
              <div class="member__avatar">
                {m.data.avatar ? (
                  <img src={m.data.avatar.src} alt={m.data.name} loading="lazy" />
                ) : (
                  <div class="member__avatar-empty">{m.data.name.split(' ').map(n => n[0]).join('').slice(0, 2)}</div>
                )}
              </div>
              <div class="member__body">
                <h3 class="member__name">{m.data.name}</h3>
                <div class="member__role">{m.data.role}</div>
                <div class="member__aff">{m.data.affiliation}</div>
                {m.data.bio && <p class="member__bio">{m.data.bio}</p>}
              </div>
            </li>
          ))}
        </ul>
      )}

      <p class="team__disclaimer">
        <em>Affiliations are listed for identification purposes only.
        The team is a voluntary research community: contributions are
        made in individual capacity and do not imply any financial
        commitment or formal endorsement on the part of the
        institutions cited.</em>
      </p>

      <p class="team__foot">
        <em>To be added to this page (after a sustained contribution),
        get in touch with the project lead. Existing members can edit
        their entry via a PR adding/updating a YAML file in
        <code>src/content/team/</code>. See the
        <a href="https://github.com/zalmoxes-laran/ExtendedMatrix-site/blob/main/EDITORS_GUIDE.md" target="_blank" rel="noopener">EDITORS_GUIDE</a>.</em>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .team { padding: 80px 0 60px; }
  .team h1 { margin: 14px 0 16px; }
  .team__sub {
    max-width: 720px;
    color: var(--em-text-muted);
    font-size: 17px;
    margin-bottom: 56px;
  }
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }
  .member {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 20px;
    padding: 24px;
    border: 1px solid var(--em-border);
    border-radius: var(--radius-md);
    background: var(--em-bg);
    transition: border-color 0.2s var(--ease);
  }
  .member:hover { border-color: var(--em-gold); }
  .member__avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--em-navy-tint);
  }
  .member__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Uniform editorial B/W treatment across the team page.
       Source images stay in colour in the repo so a future
       editorial choice (mixed colour, full colour, sepia, …)
       is a single CSS line away. Filters chain on hover/focus
       for a tiny accent. */
    filter: grayscale(100%) contrast(1.02);
    transition: filter 0.2s var(--ease);
  }
  .member:hover .member__avatar img,
  .member:focus-within .member__avatar img {
    /* Subtle dial-up on hover — still B/W, just sharper. */
    filter: grayscale(100%) contrast(1.08);
  }
  .member__avatar-empty {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--em-navy);
    font-size: 28px;
    background: var(--em-gold-tint);
  }
  .member__name { font-size: 17px; margin: 0; color: var(--em-navy); }
  .member__role {
    font-size: 13px;
    /* Accessibility: gold (#b8893a) on white is 3.14:1 — fails
       WCAG AA (4.5:1 minimum for normal text). Navy (#1a2845) on
       white is 14.6:1 — passes AAA. Gold survives as a decorative
       accent (borders, hover, separators) where the 3:1 UI-component
       threshold applies, not as a colour for text that carries
       information. */
    color: var(--em-navy);
    font-weight: 600;
    margin-top: 4px;
  }
  .member__aff {
    font-size: 12px;
    color: var(--em-text-muted);
    font-family: var(--font-mono);
    margin-top: 2px;
  }
  .member__bio {
    font-size: 14px;
    line-height: 1.6;
    color: var(--em-text);
    margin: 12px 0 0;
  }
  .member__links {
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
    display: flex;
    gap: 14px;
    font-size: 12px;
  }
  .member__links a {
    /* ORCID / EMAIL chips kept in gold by editorial choice: they are
       small accent labels (12px uppercase, letter-spaced, bold) at
       the bottom of each card, not body text — their function as
       links is reinforced by the uniform position, the uppercase
       casing and the colour shift on hover. Gold #b8893a on white is
       3.14:1: below WCAG AA for normal text (4.5:1), above the 3:1
       large-text / UI-component threshold. The role line and section
       headings (which DO carry primary information) were moved to
       navy; these label-chips stay gold so the card retains its
       warm visual rhythm. */
    color: var(--em-gold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .member__links a:hover {
    /* Hover → navy: the colour swap signals interactivity and lifts
       contrast to AAA-class while the user is actively pointing. */
    color: var(--em-navy);
  }

  /* Section heading between Active / Honorary / Committee groups */
  .team__section-h {
    margin: 40px 0 12px;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    /* Section headings used to be gold for visual consistency with
       role lines and link text. With those moved to navy for
       accessibility, gold here would isolate it as the only "warm"
       text on the page — visually orphaned. Navy keeps the page
       coherent; the section's identity is carried by the uppercase
       + letter-spacing + display font, not by the colour. */
    color: var(--em-navy);
    font-family: var(--font-display);
    font-weight: 700;
  }
  .team__section-h:first-of-type { margin-top: 8px; }
  .team__section-lede {
    color: var(--em-text-muted);
    font-size: 14px;
    line-height: 1.65;
    margin: 0 0 20px;
    max-width: 720px;
  }
  .team__section-lede--placeholder {
    font-style: italic;
    border-left: 3px solid var(--em-border);
    padding-left: 14px;
    color: var(--em-text-muted);
  }
  /* Honorary contributor cards: same shape but slightly quieter to
     signal "credited, contribution still visible in the project,
     not currently in the active rotation". (CSS class name keeps
     `--past` to match the schema enum value; only the section
     label and lede have moved to "Honorary contributors".) */
  .member--past {
    background: var(--em-bg-warm);
    border-style: dashed;
  }

  .team__disclaimer {
    margin: 40px 0 24px;
    padding: 16px 18px;
    background: var(--em-bg-warm);
    border-left: 3px solid var(--em-gold);
    border-radius: var(--radius-sm);
    color: var(--em-text-muted);
    font-size: 13px;
    line-height: 1.65;
    max-width: 760px;
  }

  .team__foot {
    margin-top: 24px;
    color: var(--em-text-muted);
    font-size: 13px;
  }
  .team__foot code {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--em-bg-warm);
    padding: 1px 6px;
    border-radius: 2px;
  }

  @media (max-width: 700px) {
    .grid { grid-template-columns: 1fr; }
    .member { grid-template-columns: 1fr; text-align: center; }
    .member__avatar { margin: 0 auto; }
    .member__links { justify-content: center; }
  }
</style>
