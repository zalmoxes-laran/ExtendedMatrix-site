---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const team = (await getCollection('team'))
  .sort((a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="Team"
  description="The people behind Extended Matrix — core maintainers, contributors and active community members."
>
  <section class="team">
    <div class="container">
      <span class="tag">Team</span>
      <h1>The people behind EM.</h1>
      <p class="team__sub">
        Extended Matrix is developed by an open community. The core
        maintainers and active contributors are listed below; many more
        people use, teach and extend EM in their own work — see the
        <a href="/projects">projects gallery</a> and the
        <a href="/about#partners">partners section</a>.
      </p>

      <ul class="grid">
        {team.map((m) => (
          <li class="member">
            <div class="member__avatar">
              {m.data.avatar ? (
                <img src={m.data.avatar.src} alt={m.data.name} loading="lazy" />
              ) : (
                <div class="member__avatar-empty">{m.data.name.split(' ').map(n => n[0]).join('').slice(0, 2)}</div>
              )}
            </div>
            <div class="member__body">
              <h2 class="member__name">{m.data.name}</h2>
              <div class="member__role">{m.data.role}</div>
              <div class="member__aff">{m.data.affiliation}</div>
              {m.data.bio && <p class="member__bio">{m.data.bio}</p>}
              <ul class="member__links">
                {m.data.orcid && <li><a href={`https://orcid.org/${m.data.orcid}`} target="_blank" rel="noopener">ORCID</a></li>}
                {m.data.email && <li><a href={`mailto:${m.data.email}`}>email</a></li>}
              </ul>
            </div>
          </li>
        ))}
      </ul>

      <p class="team__foot">
        <em>To add yourself to this page (after a sustained contribution),
        open a PR adding a YAML file in
        <code>src/content/team/</code>. See the
        <a href="https://github.com/zalmoxes-laran/ExtendedMatrix-site/blob/main/EDITORS_GUIDE.md" target="_blank" rel="noopener">EDITORS_GUIDE</a>.</em>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .team { padding: 80px 0 60px; }
  .team h1 { margin: 14px 0 16px; }
  .team__sub {
    max-width: 720px;
    color: var(--em-text-muted);
    font-size: 17px;
    margin-bottom: 56px;
  }
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }
  .member {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 20px;
    padding: 24px;
    border: 1px solid var(--em-border);
    border-radius: var(--radius-md);
    background: var(--em-bg);
    transition: border-color 0.2s var(--ease);
  }
  .member:hover { border-color: var(--em-gold); }
  .member__avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--em-navy-tint);
  }
  .member__avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .member__avatar-empty {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--em-navy);
    font-size: 28px;
    background: var(--em-gold-tint);
  }
  .member__name { font-size: 17px; margin: 0; color: var(--em-navy); }
  .member__role {
    font-size: 13px;
    color: var(--em-gold);
    font-weight: 600;
    margin-top: 4px;
  }
  .member__aff {
    font-size: 12px;
    color: var(--em-text-muted);
    font-family: var(--font-mono);
    margin-top: 2px;
  }
  .member__bio {
    font-size: 14px;
    line-height: 1.6;
    color: var(--em-text);
    margin: 12px 0 0;
  }
  .member__links {
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
    display: flex;
    gap: 14px;
    font-size: 12px;
  }
  .member__links a {
    color: var(--em-gold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }

  .team__foot {
    margin-top: 56px;
    color: var(--em-text-muted);
    font-size: 13px;
  }
  .team__foot code {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--em-bg-warm);
    padding: 1px 6px;
    border-radius: 2px;
  }

  @media (max-width: 700px) {
    .grid { grid-template-columns: 1fr; }
    .member { grid-template-columns: 1fr; text-align: center; }
    .member__avatar { margin: 0 auto; }
    .member__links { justify-content: center; }
  }
</style>
