---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import logoMark from '../assets/logo_mark.svg';
import home3dViewport from '../assets/home/3d-viewport-proxies.png';
import homeEmGraph from '../assets/home/em-graph.png';
import homeStratigraphyTree from '../assets/home/stratigraphy-tree.png';
import homeHeriverse from '../assets/home/heriverse-collaborative.png';
import heriverseLogo from '../assets/tools/heriverse.png';

const B = import.meta.env.BASE_URL.replace(/\/$/, '');

// Load partners with a logo for the "Used by" strip
const allPartners = await getCollection('partners');
const partnerLogos = allPartners
  .filter((p) => p.data.logo)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Extended Matrix">
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__copy">
        <span class="tag">Archaeological Knowledge Graph</span>
        <h1 class="hero__title">
          From evidence<br />
          to <em>interpretation</em>,<br />
          transparently.
        </h1>
        <p class="hero__sub">
          Extended Matrix is a formal language for documenting stratigraphic
          sequences and virtual reconstruction processes — designed to be
          readable by people, processable by machines.
        </p>
        <div class="hero__actions">
          <a href={`${B}/start`} class="btn btn-primary">Start here →</a>
          <a href="https://docs.extendedmatrix.org" class="btn btn-ghost" target="_blank" rel="noopener">
            Read the docs
          </a>
        </div>
      </div>
      <div class="hero__visual" aria-hidden="true">
        <img src={logoMark.src} alt="" class="hero__mark" />
        <div class="hero__diagram">
          <p class="hero__diagram-label">EM node vocabulary (excerpt)</p>
          <div class="diagram-row">
            <span class="dn dn-us">US 001</span>
            <span class="diagram-arrow">→</span>
            <span class="diagram-mono">overlies</span>
            <span class="diagram-arrow">→</span>
            <span class="dn dn-us">US 002</span>
          </div>
          <div class="diagram-row">
            <span class="dn dn-doc">DOC photo</span>
            <span class="diagram-arrow">◀··</span>
            <span class="dn dn-ext">EXT analysis</span>
            <span class="diagram-arrow">◀──</span>
            <span class="dn dn-prop">PROP dating</span>
            <span class="diagram-arrow">◀──</span>
            <span class="dn dn-usv">USV recon.</span>
          </div>
          <p class="diagram-note">
            Every reconstruction node points back to the evidence that justifies it —
            via the property, the extraction and the source.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PURPOSE / FOR ARCHAEOLOGISTS ============ -->
  <section class="purpose">
    <div class="container purpose__inner">
      <span class="tag">Why EM exists</span>
      <h2 class="purpose__title">
        Make your interpretive choices visible.
      </h2>
      <p class="purpose__lede">
        Most virtual reconstructions look certain even when the evidence
        beneath them is fragmentary, contested, or simply missing.
        Extended Matrix lets archaeologists record <em>what was found</em>,
        <em>how it was read</em>, and <em>where the reconstruction goes
        beyond the data</em> — so colleagues, reviewers and the public can
        see the reasoning, not just the result.
      </p>
      <p class="purpose__lede">
        From the stratigraphic sequence on site to the published 3D scene,
        every interpretive step stays linked to the source that justifies
        it.
      </p>
      <div class="purpose__cta">
        <a href={`${B}/start`} class="btn btn-primary">Start here →</a>
        <a href={`${B}/projects`} class="btn btn-ghost">See real projects</a>
      </div>
    </div>
  </section>

  <!-- ============ SEE IT IN PRACTICE ============ -->
  <section class="practice">
    <div class="container">
      <span class="tag">See it in practice</span>
      <h2 class="practice__title">One graph, four ways to look at it.</h2>
      <p class="practice__sub">
        The same EM data shows up in the photogrammetric model, in the
        stratigraphic graph, in the project's data tree, and in the public
        <a href={`${B}/tools/heriverse/`}>Heriverse</a> scene — each view is a different reading of the same
        knowledge.
      </p>

      <div class="practice__grid">
        <figure class="screen">
          <div class="screen__chrome">3D viewport — proxies on photogrammetric model</div>
          <div class="screen__body screen__body--img">
            <Image src={home3dViewport} alt="Blender 3D viewport showing semi-transparent proxy boxes overlaid on a photogrammetric model" widths={[480, 800, 1200]} sizes="(min-width: 980px) 50vw, 100vw" />
          </div>
        </figure>

        <figure class="screen">
          <div class="screen__chrome">EM graph — yEd / Graph Editor</div>
          <div class="screen__body screen__body--img">
            <Image src={homeEmGraph} alt="Extended Matrix graph in yEd showing stratigraphic units, properties and document nodes connected by typed edges" widths={[480, 800, 1200]} sizes="(min-width: 980px) 50vw, 100vw" />
          </div>
        </figure>

        <figure class="screen">
          <div class="screen__chrome">Stratigraphy data tree — Blender side panel</div>
          <div class="screen__body screen__body--img">
            <Image src={homeStratigraphyTree} alt="EMtools side panel in Blender showing the stratigraphic data tree of US, USV, documents, extractions and properties" widths={[480, 800, 1200]} sizes="(min-width: 980px) 50vw, 100vw" />
          </div>
        </figure>

        <figure class="screen">
          <div class="screen__chrome">Heriverse — collaborative web scene</div>
          <div class="screen__body screen__body--img">
            <Image src={homeHeriverse} alt="Heriverse web scene with a 3D reconstruction, paradata pop-up and collaborator cursors" widths={[480, 800, 1200]} sizes="(min-width: 980px) 50vw, 100vw" />
          </div>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============ LIVE HERIVERSE EMBED ============ -->
  <section class="live">
    <div class="container">
      <span class="tag">See it live</span>
      <h2 class="live__title">Explore a reconstruction in your browser.</h2>
      <p class="live__lede">
        Below is a live <a href={`${B}/tools/heriverse/`}>Heriverse</a> scene — the same EM data you saw above,
        published as an interactive 3D experience. Walk through the
        reconstruction, click on a unit, read the paradata that justifies
        each interpretive choice.
      </p>

      <div class="live__frame">
        <iframe
          src="https://strativerse-test.ispc.cnr.it/a/heriverse/?scene=scene%3Ae3bdd326-13cb-4489-a062-e035ede2563c"
          title="Heriverse — live Extended Matrix scene"
          loading="lazy"
          allow="autoplay; fullscreen; xr-spatial-tracking; execution-while-out-of-viewport; execution-while-not-rendered; web-share"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>

      <div class="live__meta">
        <a
          class="btn btn-ghost"
          href="https://strativerse-test.ispc.cnr.it/a/heriverse/?scene=scene%3Ae3bdd326-13cb-4489-a062-e035ede2563c"
          target="_blank"
          rel="noopener"
        >
          Open the live experience in a new tab →
        </a>
        <p class="live__note">
          <strong>Coming soon:</strong> the underlying open dataset will be
          released on the
          <a href="https://zenodo.org/communities/extendedmatrix" target="_blank" rel="noopener">Extended Matrix Zenodo community</a>
          (versioned, citable), accompanied by a data paper in
          <em>Heritage</em> (MDPI).
        </p>
      </div>
    </div>
  </section>

  <!-- ============ CORE IDEA ============ -->
  <section class="core">
    <div class="container core__row">
      <div>
        <span class="tag">Under the hood</span>
        <h2 class="core__title">EM is the score.<br />s3dgraphy plays it.</h2>
        <p>
          Like a musical score versus its MIDI encoding, Extended Matrix is the
          human-readable notation: it can live on paper, in yEd, or in an
          AI-extracted spreadsheet. The <strong><a href={`${B}/tools/s3dgraphy/`}>s3dgraphy</a></strong> Python
          library makes that notation computable — and the rest of the
          framework brings it into Blender, into the web, into VR.
        </p>
        <p>
          The property graph already carries CIDOC-CRM mappings, making EM
          data interoperable with the broader cultural heritage ecosystem.
        </p>
        <a href={`${B}/start`} class="btn btn-gold" style="margin-top: 8px;">
          Pick your starting point →
        </a>
      </div>
      <div class="core__visual" aria-hidden="true">
        <pre class="cv-block">
                              <span class="cv-node cv-doc">DOC_001</span>
                                 <span class="cv-arrow">│ extracted_from</span>
                                 <span class="cv-arrow">▼</span>
                              <span class="cv-node cv-ext">EXT_001</span>
                                 <span class="cv-arrow">│ supports</span>
                                 <span class="cv-arrow">▼</span>
                              <span class="cv-node cv-prop">PROP_dating</span>
                                 <span class="cv-arrow">│ has_property</span>
                                 <span class="cv-arrow">▼</span>
<span class="cv-node cv-usv">USV_001</span>  <span class="cv-arrow">─ overlies ─▶</span>  <span class="cv-node cv-us">US_002</span>
        </pre>
        <p class="diagram-note">
          Every reconstruction node carries its full provenance chain —
          property → extraction → source.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ EM FRAMEWORK ============ -->
  <section class="framework">
    <div class="container">
      <span class="tag">EM Framework</span>
      <h2 class="framework__title">The tools that speak EM</h2>
      <p class="framework__sub">
        A growing family of open-source tools built around the <a href={`${B}/tools/s3dgraphy/`}>s3dgraphy</a>
        knowledge graph — from field documentation to immersive web
        publication.
      </p>

      <div class="framework__grid">
        <a href={`${B}/tools/em-tools/`} class="card">
          <div class="card__name">EM Tools</div>
          <div class="card__role">Blender add-on</div>
          <p class="card__desc">
            3D visualisation and interactive annotation of stratigraphic units
            directly inside Blender.
          </p>
        </a>
        <a href={`${B}/tools/s3dgraphy/`} class="card">
          <div class="card__name">s3dgraphy</div>
          <div class="card__role">Python library</div>
          <p class="card__desc">
            The graph engine: import, export, validate and query EM knowledge
            graphs.
          </p>
        </a>
        <a href={`${B}/tools/heriverse/`} class="card card--with-icon">
          <Image
            src={heriverseLogo}
            alt=""
            widths={[48, 96]}
            sizes="40px"
            class="card__icon"
          />
          <div class="card__body">
            <div class="card__name">Heriverse</div>
            <div class="card__role">Web platform</div>
            <p class="card__desc">
              Heritage Science Metaverse — paradata pop-ups, epoch switching,
              collaborative VR for EM-aware scenes.
            </p>
          </div>
        </a>
        <a href={`${B}/tools/3dsc/`} class="card">
          <div class="card__name">3DSC</div>
          <div class="card__role">Survey pipeline</div>
          <p class="card__desc">
            Photogrammetry and 3D model preparation upstream of EM Tools, on
            modest hardware.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ MODULAR ============ -->
  <section class="modular">
    <div class="container">
      <span class="tag">Modular by design</span>
      <h2 class="modular__title">A framework, not a single application.</h2>
      <p class="modular__lede">
        The EM Framework is split into focused components —
        <a href={`${B}/tools/yed-palette/`}>yEd palette</a>,
        <a href={`${B}/tools/s3dgraphy/`}>s3dgraphy</a>,
        <a href={`${B}/tools/em-tools/`}>EM Tools</a>,
        <a href={`${B}/tools/3dsc/`}>3DSC</a>,
        <a href={`${B}/tools/heriverse/`}>Heriverse</a> — each with its own repository,
        documentation and release cycle. You pick what you need. The shared
        graph format keeps every piece in sync.
      </p>
      <p class="modular__lede">
        Bringing EM into another platform — Revit, 3ds Max, Unity, Unreal,
        a CLI batch job — is a <code>pip install s3dgraphy</code> away. The
        data model is the same everywhere, including its CIDOC-CRM mapping.
      </p>
      <div class="modular__cta">
        <a href={`${B}/tools`} class="btn btn-primary">Browse the tools →</a>
        <a href={`${B}/download`} class="btn btn-ghost">Download a release</a>
      </div>
    </div>
  </section>

  <!-- ============ STANDARDS & ALIGNMENT ============ -->
  <section class="standards">
    <div class="container">
      <span class="tag">Built on standards</span>
      <h2 class="standards__title">Long-term support, real interoperability.</h2>
      <p class="standards__sub">
        Extended Matrix is part of the European research infrastructure for
        cultural heritage. It is committed to long-term standardisation,
        formal mapping to community ontologies, and integration with the
        emerging European Collaborative Cloud.
      </p>

      <div class="standards__grid">
        <article class="std-card">
          <div class="std-card__head">CIDOC-CRM alignment</div>
          <p>
            Every EM node and arc has a published mapping to the ISO
            CIDOC-CRM ontology. Your graph is interoperable with the rest
            of the cultural-heritage data world out of the box.
          </p>
        </article>
        <article class="std-card">
          <div class="std-card__head">LTS releases</div>
          <p>
            From version 1.5, the formal language follows a long-term support
            cycle: stable releases are maintained for years with backwards
            compatibility, breaking changes are governed.
          </p>
          <p class="std-card__cta">
            <a href="http://dev.extendedmatrix.org/dev-projects/" target="_blank" rel="noopener noreferrer">
              View detailed release status &amp; development projects →
            </a>
          </p>
        </article>
        <article class="std-card">
          <div class="std-card__head">ECCCH connector</div>
          <p>
            EM is one of the building blocks of the
            <a href="https://www.eccch.eu" target="_blank" rel="noopener">European Collaborative Cloud for Cultural Heritage</a>:
            <a href={`${B}/tools/em-tools/`}>EM Tools</a> and <a href={`${B}/tools/heriverse/`}>Heriverse</a> will publish first-class connectors to
            the federated nodes.
          </p>
        </article>
        <article class="std-card">
          <div class="std-card__head">StratiGraph EU project (2025–2029)</div>
          <p>
            Extended Matrix is being developed (2025–2029) within the
            <strong>StratiGraph</strong> project, funded under the
            <a href="https://www.eccch.eu" target="_blank" rel="noopener">European Collaborative Cloud for Cultural Heritage (ECCCH)</a>.
            StratiGraph hardens EM as shared infrastructure: governance,
            versioning, validation suite, and reference triplestore export.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ CITE EM ============ -->
  <section class="cite-prompt">
    <div class="container cite-prompt__row">
      <div>
        <span class="tag">Citing EM</span>
        <h2 class="cite-prompt__title">Used EM in a paper? Cite it the right way.</h2>
        <p class="cite-prompt__lede">
          Extended Matrix grows version after version. The
          <strong>2015 foundation paper</strong> is always cited; each
          release additionally contributes a <strong>flag paper</strong>
          you cite when you used features it introduced. The
          <a href={`${B}/cite`}>How to cite EM</a> page assembles the
          full list per version, with ready-made BibTeX, and links to
          the canonical
          <a href="https://docs.extendedmatrix.org/en/latest/references.html" target="_blank" rel="noopener">References</a>
          and
          <a href="https://docs.extendedmatrix.org/en/latest/glossary.html" target="_blank" rel="noopener">Glossary</a>
          pages of the language documentation.
        </p>
        <a href={`${B}/cite`} class="btn btn-ghost">How to cite EM →</a>
      </div>
    </div>
  </section>

  <!-- ============ OPEN DATA ============ -->
  <section class="opendata">
    <div class="container">
      <span class="tag">Open data</span>
      <h2 class="opendata__title">EM datasets on Zenodo.</h2>
      <p class="opendata__lede">
        Reference datasets, training material and case-study GraphML can be
        deposited on the
        <a href="https://zenodo.org/communities/extendedmatrix" target="_blank" rel="noopener">Extended Matrix Zenodo community</a>
        — every deposit gets a DOI and is preserved for the long term. The
        first fully downloadable case study (the Great Temple of
        Sarmizegetusa) is being prepared, alongside a dedicated deposit
        protocol.
      </p>
      <p class="opendata__lede">
        <strong>Coming soon:</strong> each released case study will be
        published as a versioned dataset on Zenodo and cited by an
        accompanying data paper in <em>Heritage</em> (MDPI), so the
        underlying evidence stays as citable as the reconstruction itself.
      </p>
      <a href="https://zenodo.org/communities/extendedmatrix" class="btn btn-ghost" target="_blank" rel="noopener">
        Browse the EM Zenodo community →
      </a>
    </div>
  </section>

  <!-- ============ USED BY ============ -->
  <section class="usedby">
    <div class="container">
      <span class="tag">Used by &amp; collaborations</span>
      <h2 class="usedby__title">Universities, research institutions, European projects.</h2>
      <p class="usedby__sub">
        EM is adopted, funded and co-developed by —
      </p>

      {partnerLogos.length > 0 ? (
        <ul class="usedby__strip">
          {partnerLogos.map((p) => (
            <li>
              {p.data.url ? (
                <a href={p.data.url} target="_blank" rel="noopener" title={p.data.name}>
                  <img src={p.data.logo!.src} alt={p.data.logoAlt || p.data.name} loading="lazy" />
                </a>
              ) : (
                <img src={p.data.logo!.src} alt={p.data.logoAlt || p.data.name} title={p.data.name} loading="lazy" />
              )}
            </li>
          ))}
        </ul>
      ) : (
        <p class="usedby__empty">Logos coming soon.</p>
      )}

      <p class="usedby__more">
        See the full list on the <a href={`${B}/about#partners`}>about page</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ───────────────────────────────────────────────── */
  .hero {
    background: var(--em-navy);
    color: var(--em-bg);
    padding: 100px 0 80px;
    overflow: hidden;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .hero :global(.tag) {
    color: var(--em-gold);
    background: rgba(184, 137, 58, 0.15);
    border: 1px solid rgba(184, 137, 58, 0.4);
  }
  .hero__title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    margin: 18px 0 22px;
    color: var(--em-bg);
  }
  .hero__title em {
    font-style: normal;
    color: var(--em-gold);
  }
  .hero__sub {
    font-size: 17px;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 480px;
  }
  .hero__actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .hero__actions :global(.btn-primary) {
    background: var(--em-gold);
    color: var(--em-navy);
  }
  .hero__actions :global(.btn-primary:hover) {
    background: var(--em-gold-soft);
    color: var(--em-navy);
  }
  .hero__actions :global(.btn-ghost) {
    color: var(--em-bg);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .hero__actions :global(.btn-ghost:hover) {
    background: rgba(255, 255, 255, 0.1);
    color: var(--em-bg);
    border-color: var(--em-bg);
  }
  .hero__visual {
    position: relative;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    padding: 36px 32px 32px;
  }
  .hero__mark {
    position: absolute;
    top: -24px;
    right: -24px;
    width: 80px;
    opacity: 0.18;
    filter: invert(1);
  }
  .hero__diagram-label {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 14px;
  }
  .diagram-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .dn {
    padding: 7px 14px;
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }
  .dn-us  { background: rgba(184, 137, 58, 0.15); color: var(--em-gold); border: 1px solid var(--em-gold); }
  .dn-usv { background: rgba(184, 137, 58, 0.08); color: var(--em-gold-soft); border: 1px dashed var(--em-gold); }
  .dn-doc  { background: rgba(255, 255, 255, 0.07); color: rgba(255, 255, 255, 0.85); border: 1px solid rgba(255, 255, 255, 0.3); }
  .dn-ext  { background: rgba(255, 255, 255, 0.04); color: rgba(255, 255, 255, 0.7); border: 1px dotted rgba(255, 255, 255, 0.4); }
  .dn-prop { background: rgba(184, 137, 58, 0.04); color: rgba(255, 255, 255, 0.85); border: 1px solid rgba(184, 137, 58, 0.5); }
  .diagram-arrow { color: rgba(255, 255, 255, 0.5); font-size: 16px; font-family: var(--font-mono); }
  .diagram-mono { font-family: var(--font-mono); font-size: 11px; color: rgba(255, 255, 255, 0.55); }
  .diagram-note {
    margin-top: 14px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.55);
    font-style: italic;
  }

  /* ── Core idea ──────────────────────────────────────────── */
  .core {
    background: var(--em-bg-warm);
    border-block: 1px solid var(--em-border);
  }
  .core__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .core__title { margin: 12px 0 18px; }
  .core__visual {
    background: var(--em-bg);
    border: 1px solid var(--em-border);
    border-radius: var(--radius-md);
    padding: 28px;
  }
  .cv-block {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 2;
    color: var(--em-text);
    white-space: pre-wrap;
    margin: 0;
  }
  .core .diagram-note { color: var(--em-text-muted); margin-top: 14px; }
  .cv-node {
    padding: 2px 10px;
    border-radius: 2px;
    font-weight: 700;
  }
  .cv-us  { background: var(--em-gold-tint); color: var(--em-gold); }
  .cv-usv { background: var(--em-gold-tint); color: var(--em-gold-soft); border: 1px dashed var(--em-gold); }
  .cv-doc  { background: var(--em-navy-tint); color: var(--em-navy); }
  .cv-ext  { background: var(--em-navy-tint); color: var(--em-navy-soft); }
  .cv-prop { background: var(--em-gold-tint); color: var(--em-gold); }
  .cv-arrow { color: var(--em-text-muted); }

  /* ── Framework ──────────────────────────────────────────── */
  .framework__title { margin: 12px 0 16px; }
  .framework__sub {
    color: var(--em-text-muted);
    max-width: 600px;
    margin-bottom: 40px;
  }
  .framework__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .card {
