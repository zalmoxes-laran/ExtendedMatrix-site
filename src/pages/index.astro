  .vocab-carousel:focus-within .vc-track {
    animation-play-state: paused;
  }
  @keyframes vc-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
