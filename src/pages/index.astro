  .dn__glyph {
    display: inline-block;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    background-color: currentColor;
    -webkit-mask-image: var(--g);
    mask-image: var(--g);
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    opacity: 0.85;
  }
  .dn-us  { background: rgba(184, 137, 58, 0.15); color: var(--em-gold); border: 1px solid var(--em-gold); }
