---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const all = (await getCollection('cookbook'))
  .filter((r) => !r.data.draft)
  .sort((a, b) => (b.data.order ?? 0) - (a.data.order ?? 0) || a.data.title.localeCompare(b.data.title));

const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Cookbook"
  description="Cross-tool recipes for the Extended Matrix ecosystem — operational walkthroughs that orchestrate EM language, EM Tools, s3dgraphy, 3DSC and Heriverse to solve a concrete archaeological problem end-to-end."
>
  <section class="cb">
    <div class="container">
      <span class="tag">Cookbook</span>
      <h1>Recipes for the EM ecosystem.</h1>
      <p class="cb__sub">
        Cross-tool walkthroughs that orchestrate <strong>EM language</strong>,
        <strong>EM Tools</strong>, <strong>s3dgraphy</strong>, <strong>3DSC</strong>
        and <strong>Heriverse</strong> to solve a concrete archaeological problem
        end-to-end. Each recipe links into the canonical tool manual at the
        right depth rather than duplicating reference content — the recipe is
        the operational glue between manuals, not a fifth source of truth.
      </p>

      {all.length === 0 ? (
        <p class="cb__empty">
          The cookbook is being seeded. Recipes will appear here as they are
          authored — see the project tracker for what is in flight.
        </p>
      ) : (
        <ul class="cb__grid">
          {all.map((r) => (
            <li class="cb__card">
              <a href={`${B}/cookbook/${r.id.replace(/\.md$/, '')}/`}>
                <div class="cb__cover">
                  {r.data.cover ? (
                    <img src={r.data.cover.src} alt={r.data.coverAlt || r.data.title} loading="lazy" width="320" height="200" />
                  ) : (
                    <div class="cb__placeholder">📖</div>
                  )}
                </div>
                <div class="cb__body">
                  <h3 class="cb__title">{r.data.title}</h3>
                  <p class="cb__summary">{r.data.summary}</p>
                  {r.data.tools_used.length > 0 && (
                    <div class="cb__tools">
                      {r.data.tools_used.map((t) => (
                        <span class="cb__tool-badge">{t}</span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .cb { padding: 60px 0 80px; }
  .cb h1 { margin: 14px 0 16px; }
  .cb__sub {
    max-width: 720px;
    color: var(--em-text-muted);
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 40px;
  }
  .cb__empty {
    color: var(--em-text-muted);
    font-style: italic;
    border: 1px dashed var(--em-border);
    padding: 24px 28px;
    border-radius: var(--radius-md);
    max-width: 720px;
  }
  .cb__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .cb__card {
    border: 1px solid var(--em-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--em-bg);
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .cb__card:hover { border-color: var(--em-gold); transform: translateY(-2px); }
  .cb__card a { display: block; text-decoration: none; color: inherit; }
  .cb__cover {
    aspect-ratio: 16/9;
    background: var(--em-bg-warm);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cb__cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cb__placeholder { font-size: 48px; opacity: 0.4; }
  .cb__body { padding: 20px 22px 22px; }
  .cb__title {
    font-size: 19px;
    color: var(--em-navy);
    margin: 0 0 8px;
    font-family: var(--font-display);
  }
  .cb__summary {
    font-size: 14px;
    color: var(--em-text);
    line-height: 1.55;
    margin: 0 0 14px;
  }
  .cb__tools {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .cb__tool-badge {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 10px;
    border-radius: 12px;
    background: var(--em-navy-tint);
    color: var(--em-navy);
    font-weight: 600;
  }
</style>
