---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const recipes = await getCollection('cookbook');
  return recipes.map((r) => ({
    params: { slug: r.id.replace(/\.md$/, '') },
    props: { recipe: r },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);

const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={recipe.data.title}
  description={recipe.data.summary}
>
  <article class="rc">
    <div class="container">
      <a href={`${B}/cookbook/`} class="rc__back">← All recipes</a>

      <h1 class="rc__title">{recipe.data.title}</h1>
      <p class="rc__lede">{recipe.data.summary}</p>

      {recipe.data.tools_used.length > 0 && (
        <div class="rc__tools">
          <span class="rc__tools-label">Tools used:</span>
          {recipe.data.tools_used.map((t) => (
            <a class="rc__tool-badge" href={`${B}/tools/${t}/`}>{t}</a>
          ))}
        </div>
      )}

      {recipe.data.cover && (
        <figure class="rc__cover">
          <img src={recipe.data.cover.src}
               alt={recipe.data.coverAlt || recipe.data.title}
               loading="eager" />
        </figure>
      )}

      <div class="rc__body">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .rc { padding: 60px 0 80px; }
  .rc__back {
    display: inline-block;
    font-size: 13px;
    color: var(--em-text-muted);
    margin-bottom: 16px;
  }
  .rc__title { margin: 0 0 16px; }
  .rc__lede {
    max-width: 760px;
    font-size: 17px;
    color: var(--em-text);
    line-height: 1.65;
    margin-bottom: 24px;
  }
  .rc__tools {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin-bottom: 32px;
    font-size: 13px;
  }
  .rc__tools-label {
    color: var(--em-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    margin-right: 4px;
  }
  .rc__tool-badge {
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 14px;
    background: var(--em-navy-tint);
    color: var(--em-navy);
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s var(--ease);
  }
  .rc__tool-badge:hover {
    background: var(--em-navy);
    color: var(--em-bg);
    text-decoration: none;
  }
  .rc__cover {
    max-width: 60%;
    margin: 0 auto 40px;
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .rc__cover img {
    max-width: 100%;
    width: auto;
    height: auto;
    display: block;
    margin: 0 auto;
  }
  .rc__body :global(h2) { margin-top: 32px; }
  .rc__body :global(h3) { margin-top: 22px; }
  .rc__body :global(p)  { margin-bottom: 14px; line-height: 1.7; }
  .rc__body :global(ul), .rc__body :global(ol) { margin-bottom: 14px; padding-left: 22px; }
  .rc__body :global(li) { margin-bottom: 6px; }
  .rc__body :global(code) {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--em-navy-tint);
    color: var(--em-navy);
    padding: 1px 6px;
    border-radius: 2px;
  }
  .rc__body :global(pre) {
    background: var(--em-bg-warm);
    border: 1px solid var(--em-border);
    padding: 14px 18px;
    border-radius: var(--radius-md);
    overflow-x: auto;
    font-size: 13px;
  }
  .rc__body :global(pre code) { background: none; color: inherit; padding: 0; }
  .rc__body :global(p:has(> img:only-child)) {
    margin: 28px 0 4px;
    text-align: center;
  }
  .rc__body :global(p:has(> img:only-child) img) {
    max-width: 60%;
    height: auto;
    display: block;
    margin: 0 auto;
    border-radius: var(--radius-sm);
  }
  @media (max-width: 768px) {
    .rc__cover { max-width: 100%; }
    .rc__body :global(p:has(> img:only-child) img) { max-width: 100%; }
  }
</style>
