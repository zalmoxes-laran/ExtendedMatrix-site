---
import BaseLayout from '../layouts/BaseLayout.astro';
const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Visitor statistics"
  description="Where Extended Matrix readers come from since the site relaunch on June 2, 2026. Aggregated by country, cookieless, no individual IPs."
>
  <section class="stats">
    <div class="container">
      <span class="tag">Open analytics</span>
      <h1 class="stats__title">Where readers come from</h1>
      <p class="stats__lede">
        Visitors to <strong>extendedmatrix.org</strong> since the site
        relaunch on <strong>June 2, 2026</strong>. Aggregated by country,
        cookieless, no individual IPs, refreshed once a day from our
        analytics provider.
      </p>

      <!-- Globe placeholder; populated client-side after globe.gl + data load. -->
      <div class="stats__globe" id="stats-globe" aria-label="Interactive globe with visitor locations">
        <div class="stats__globe-loading">Loading globe…</div>
      </div>

      <div class="stats__panel">
        <div class="stats__counter">
          <div class="stats__counter-num" id="stats-total">—</div>
          <div class="stats__counter-label">Total visits since relaunch</div>
          <div class="stats__counter-sub" id="stats-range">—</div>
        </div>

        <div class="stats__table-wrap">
          <h2>Top countries</h2>
          <table class="stats__table" id="stats-table">
            <thead>
              <tr><th>Country</th><th>Visits</th></tr>
            </thead>
            <tbody id="stats-tbody">
              <tr><td colspan="2" style="opacity:0.6">Loading…</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <p class="stats__privacy">
        Numbers come from <a href="https://www.goatcounter.com/" target="_blank" rel="noopener">GoatCounter</a> —
        a privacy-friendly, EU-hosted, open-source analytics service that
        does <strong>not use cookies</strong> and does <strong>not log
        individual IP addresses</strong>. Locations are derived from a
        country-level IP geo-database, then aggregated and discarded.
        See the <a href={`${B}/privacy`}>Privacy page</a> for the full
        list of what is and isn't collected.
      </p>
    </div>
  </section>

  <!-- globe.gl from a pinned CDN version. ~150KB gzipped; loaded only on /stats. -->
  <script is:inline src="https://unpkg.com/three@0.150.0/build/three.min.js"></script>
  <script is:inline src="https://unpkg.com/globe.gl@2.27.3/dist/globe.gl.min.js"></script>

  <script is:inline define:vars={{ B }}>
    // Country centroids — ISO-3166-1 alpha-2 → [latitude, longitude].
    // Covers ~120 countries: Europe, Americas, key Asia, Africa & Oceania.
    // Missing entries fall back gracefully (counted in the table but not
    // plotted on the globe). Source: aggregated from public datasets,
    // values rounded to 0.1°.
    const CENTROIDS = {
      AD:[42.5,1.5], AE:[24.0,54.0], AF:[33.0,66.0], AL:[41.0,20.0], AM:[40.0,45.0],
      AO:[-12.5,18.5], AR:[-34.0,-64.0], AT:[47.3,13.3], AU:[-27.0,133.0], AZ:[40.5,47.5],
      BA:[44.0,18.0], BD:[24.0,90.0], BE:[50.8,4.0], BF:[13.0,-2.0], BG:[43.0,25.0],
      BH:[26.0,50.5], BI:[-3.5,30.0], BJ:[9.5,2.3], BO:[-17.0,-65.0], BR:[-10.0,-55.0],
      BW:[-22.0,24.0], BY:[53.0,28.0], BZ:[17.0,-88.7], CA:[60.0,-95.0], CD:[0.0,25.0],
      CF:[7.0,21.0], CG:[-1.0,15.0], CH:[46.8,8.2], CI:[7.5,-5.5], CL:[-30.0,-71.0],
      CM:[6.0,12.0], CN:[35.0,105.0], CO:[4.0,-72.0], CR:[10.0,-84.0], CU:[21.5,-80.0],
      CV:[16.0,-24.0], CY:[35.0,33.0], CZ:[49.7,15.5], DE:[51.0,9.0], DJ:[11.5,43.0],
      DK:[56.0,10.0], DO:[19.0,-70.7], DZ:[28.0,3.0], EC:[-1.4,-78.5], EE:[59.0,26.0],
      EG:[27.0,30.0], ER:[15.0,39.0], ES:[40.2,-3.7], ET:[8.0,38.0], FI:[64.0,26.0],
      FJ:[-18.0,178.0], FR:[46.6,2.2], GA:[-1.0,11.7], GB:[54.0,-2.0], GE:[42.0,43.5],
      GH:[8.0,-2.0], GR:[39.0,22.0], GT:[15.5,-90.3], HN:[15.0,-86.5], HR:[45.2,15.5],
      HT:[19.0,-72.5], HU:[47.0,20.0], ID:[-5.0,120.0], IE:[53.0,-8.0], IL:[31.5,34.8],
      IN:[20.0,77.0], IQ:[33.0,44.0], IR:[32.0,53.0], IS:[65.0,-18.0], IT:[42.5,12.5],
      JM:[18.2,-77.5], JO:[31.0,36.0], JP:[36.0,138.0], KE:[1.0,38.0], KG:[41.0,75.0],
      KH:[13.0,105.0], KP:[40.0,127.0], KR:[37.0,127.5], KW:[29.5,47.8], KZ:[48.0,68.0],
      LA:[18.0,105.0], LB:[33.8,35.8], LK:[7.0,81.0], LR:[6.5,-9.5], LT:[55.4,23.9],
      LU:[49.8,6.1], LV:[57.0,25.0], LY:[25.0,17.0], MA:[32.0,-5.0], MD:[47.0,28.5],
      ME:[42.7,19.3], MG:[-20.0,47.0], MK:[41.6,21.7], ML:[17.0,-4.0], MM:[22.0,98.0],
      MN:[46.0,105.0], MR:[20.0,-12.0], MT:[35.9,14.5], MU:[-20.3,57.5], MX:[23.0,-102.0],
      MY:[2.5,112.5], MZ:[-18.3,35.0], NA:[-22.0,17.0], NE:[16.0,8.0], NG:[10.0,8.0],
      NI:[13.0,-85.0], NL:[52.5,5.8], NO:[62.0,10.0], NP:[28.0,84.0], NZ:[-41.0,174.0],
      OM:[21.0,57.0], PA:[9.0,-80.0], PE:[-10.0,-76.0], PG:[-6.0,147.0], PH:[13.0,122.0],
      PK:[30.0,70.0], PL:[52.0,20.0], PR:[18.2,-66.4], PS:[31.9,35.2], PT:[39.5,-8.0],
      PY:[-23.0,-58.0], QA:[25.5,51.2], RO:[46.0,25.0], RS:[44.0,21.0], RU:[60.0,100.0],
      RW:[-2.0,30.0], SA:[25.0,45.0], SD:[15.0,30.0], SE:[62.0,15.0], SG:[1.3,103.8],
      SI:[46.1,14.8], SK:[48.7,19.5], SN:[14.0,-14.0], SO:[6.0,46.0], SR:[4.0,-56.0],
      SS:[8.0,30.0], SV:[13.7,-88.9], SY:[35.0,38.0], TD:[15.0,19.0], TG:[8.0,1.2],
      TH:[15.0,100.0], TJ:[39.0,71.0], TM:[40.0,60.0], TN:[34.0,9.0], TR:[39.0,35.0],
      TT:[11.0,-61.0], TW:[23.5,121.0], TZ:[-6.0,35.0], UA:[49.0,32.0], UG:[1.0,32.0],
      US:[39.0,-98.0], UY:[-33.0,-56.0], UZ:[41.0,64.0], VE:[8.0,-66.0], VN:[16.0,108.0],
      YE:[15.0,48.0], ZA:[-29.0,24.0], ZM:[-15.0,28.0], ZW:[-19.0,29.0],
    };

    const COUNTRY_FLAG = (code) => {
      if (!code || code.length !== 2) return '';
      return String.fromCodePoint(
        0x1F1E6 + code.charCodeAt(0) - 65,
        0x1F1E6 + code.charCodeAt(1) - 65
      );
    };

    function fmtNumber(n) {
      try { return new Intl.NumberFormat('en-GB').format(n); } catch { return String(n); }
    }

    async function loadVisits() {
      const res = await fetch(`${B}/data/visits.json`, { cache: 'no-store' });
      if (!res.ok) throw new Error(`visits.json HTTP ${res.status}`);
      return res.json();
    }

    function buildGlobe(container, data) {
      const countries = data.countries || [];
      const max = countries.reduce((a, c) => Math.max(a, c.count || 0), 1);

      const points = countries
        .filter((c) => CENTROIDS[c.code])
        .map((c) => {
          const [lat, lng] = CENTROIDS[c.code];
          // Logarithmic scale so a country with 1 hit still shows a visible
          // dot while the top country doesn't dwarf everything else.
          const norm = Math.log(c.count + 1) / Math.log(max + 1);
          return {
            lat,
            lng,
            size: 0.3 + norm * 0.8,
            color: norm > 0.5 ? '#c9a23e' : '#5b8dc2',
            count: c.count,
            name: c.name,
            code: c.code,
          };
        });

      // Empty the loading placeholder before mounting.
      container.innerHTML = '';

      // Read container box up front so the globe canvas is sized
      // deterministically — relying on globe.gl's auto-detection at
      // init time can yield off-centre rendering when the parent
      // grid finishes layout after the init call.
      const w = container.clientWidth;
      const h = container.clientHeight;

      const globe = window.Globe()(container)
        .width(w)
        .height(h)
        .globeImageUrl('https://unpkg.com/three-globe@2.31.0/example/img/earth-night.jpg')
        .bumpImageUrl('https://unpkg.com/three-globe@2.31.0/example/img/earth-topology.png')
        .backgroundColor('rgba(0,0,0,0)')
        .pointsData(points)
        .pointAltitude((d) => d.size * 0.04)
        .pointRadius((d) => 0.3 + d.size * 0.5)
        .pointColor((d) => d.color)
        .pointLabel((d) => `
          <div style="background:#fff; color:#1a2940; padding:6px 10px;
                      border-radius:6px; font-family:Inter,sans-serif;
                      font-size:13px; box-shadow:0 4px 14px rgba(0,0,0,0.2);">
            <strong>${COUNTRY_FLAG(d.code)} ${d.name}</strong><br/>
            ${fmtNumber(d.count)} visits
          </div>
        `);

      // Initial point of view — looking at the average longitude of
      // the active data so the sphere doesn't open on an empty
      // Pacific. Falls back to (30, 10) which already keeps Europe
      // and Africa in frame.
      const lngs = points.map((d) => d.lng);
      const meanLng = lngs.length
        ? lngs.reduce((a, b) => a + b, 0) / lngs.length
        : 10;
      globe.pointOfView({ lat: 30, lng: meanLng, altitude: 2.2 }, 0);

      // Auto-rotate, paused on hover.
      const controls = globe.controls();
      controls.autoRotate = true;
      controls.autoRotateSpeed = 0.6;
      container.addEventListener('mouseenter', () => { controls.autoRotate = false; });
      container.addEventListener('mouseleave', () => { controls.autoRotate = true; });
      container.addEventListener('focusin',    () => { controls.autoRotate = false; });
      container.addEventListener('focusout',   () => { controls.autoRotate = true; });

      // Reduced-motion: stop auto-rotation entirely.
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        controls.autoRotate = false;
      }

      // Keep the canvas in sync with container size on viewport resize
      // (e.g. mobile orientation change, browser-zoom, devtools toggle).
      const handleResize = () => {
        globe.width(container.clientWidth);
        globe.height(container.clientHeight);
      };
      window.addEventListener('resize', handleResize, { passive: true });
    }

    function buildPanel(data) {
      const total = document.getElementById('stats-total');
      const range = document.getElementById('stats-range');
      const tbody = document.getElementById('stats-tbody');

      total.textContent = fmtNumber(data.total || 0);
      const start = (data.range && data.range.start) || '2026-06-02';
      const end = (data.range && data.range.end) || '—';
      range.textContent = `${start} → ${end}`;

      const rows = (data.countries || []).slice(0, 12);
      if (rows.length === 0) {
        tbody.innerHTML = '<tr><td colspan="2" style="opacity:0.6">No data yet.</td></tr>';
        return;
      }
      tbody.innerHTML = rows.map((c) => `
        <tr>
          <td><span class="stats__flag">${COUNTRY_FLAG(c.code)}</span> ${c.name}
              <span class="stats__code">${c.code}</span></td>
          <td class="stats__count">${fmtNumber(c.count)}</td>
        </tr>
      `).join('');
    }

    async function init() {
      const container = document.getElementById('stats-globe');
      try {
        const data = await loadVisits();
        buildPanel(data);
        // Wait one paint so the container has its final width before globe.gl
        // reads it; cheap and avoids a layout glitch on slow connections.
        requestAnimationFrame(() => buildGlobe(container, data));
      } catch (err) {
        console.error('[stats] visits.json load failed:', err);
        container.innerHTML = '<div style="padding:40px; text-align:center; opacity:0.6;">Globe data unavailable right now. Refresh in a few minutes.</div>';
        document.getElementById('stats-tbody').innerHTML = '<tr><td colspan="2" style="opacity:0.6">Data unavailable.</td></tr>';
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  </script>
</BaseLayout>

<style>
  .stats { padding: 60px 0 80px; }
  .stats__title { margin: 14px 0 12px; }
  .stats__lede {
    max-width: 720px;
    color: var(--em-text-muted);
    margin-bottom: 28px;
  }
  .stats__globe {
    position: relative;
    width: 100%;
    height: 520px;
    background: radial-gradient(ellipse at center,
                #0d1a2e 0%, #050a14 70%, #020409 100%);
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--em-border);
    margin-bottom: 24px;
    /* Centre the globe.gl-injected canvas. The library appends a
       child <div class="scene-container"> + <canvas> that does not
       always self-centre when its computed width does not match the
       container's. Flex centring guarantees the sphere sits in the
       middle even if globe.gl miscalculates by a few pixels. */
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .stats__globe :global(canvas) {
    display: block;
    margin: 0 auto;
  }
  .stats__globe :global(.scene-container) {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .stats__globe-loading {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.55);
    font-size: 14px;
  }

  .stats__panel {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 32px;
    align-items: start;
    margin-bottom: 32px;
  }
  .stats__counter {
    background: var(--em-bg);
    border: 1px solid var(--em-border);
    border-radius: var(--radius-md);
    padding: 24px;
    text-align: center;
  }
  .stats__counter-num {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 700;
    color: var(--em-navy);
    line-height: 1;
  }
  .stats__counter-label {
    margin-top: 6px;
    font-size: 13px;
    color: var(--em-text-muted);
  }
  .stats__counter-sub {
    margin-top: 10px;
    font-size: 11px;
    color: var(--em-text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .stats__table-wrap h2 { margin: 0 0 14px; font-size: 18px; }
  .stats__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .stats__table th {
    text-align: left;
    padding: 8px 12px;
    border-bottom: 2px solid var(--em-border);
    font-weight: 700;
    color: var(--em-text-muted);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .stats__table td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--em-border);
  }
  .stats__flag { margin-right: 8px; font-size: 18px; }
  .stats__code {
    margin-left: 6px;
    font-size: 11px;
    color: var(--em-text-muted);
    font-family: var(--font-mono, monospace);
  }
  .stats__count { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; }

  .stats__privacy {
    background: var(--em-bg);
    border-left: 3px solid var(--em-gold);
    padding: 14px 18px;
    font-size: 13px;
    color: var(--em-text-muted);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  @media (max-width: 720px) {
    .stats__panel { grid-template-columns: 1fr; }
    .stats__globe { height: 380px; }
  }
</style>
