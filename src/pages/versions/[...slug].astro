---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const versions = await getCollection('versions');
  return versions.map((v) => ({
    params: { slug: v.id.replace(/\.md$/, '') },
    props: { version: v },
  }));
}

const { version } = Astro.props;
const { Content } = await render(version);

const B = import.meta.env.BASE_URL.replace(/\/$/, '');

// Stable id used for GoatCounter event-ids (e.g. "1-5").
const versionSlug = version.id.replace(/\.md$/, '');

// Version-switcher data ------------------------------------------------
// The user reaches a version page through Find Your Path, the homepage
// or a deep link, and frequently wants to compare the same content
// across a couple of adjacent releases. The chip strip near the top of
// the page lets them jump between versions without bouncing back to
// the index. Sorted by version number descending so the latest /
// development line is leftmost — the place the eye lands first.
const allVersions = await getCollection('versions');
const versionChips = allVersions
  .map((v) => ({
    slug: v.id.replace(/\.md$/, ''),
    label: v.data.version,
    status: v.data.status,
  }))
  .sort((a, b) => {
    // Numeric compare on dotted version strings (1.10 > 1.6).
    const pa = a.label.split('.').map(Number);
    const pb = b.label.split('.').map(Number);
    for (let i = 0; i < Math.max(pa.length, pb.length); i++) {
      const da = pa[i] ?? 0, db = pb[i] ?? 0;
      if (da !== db) return db - da;
    }
    return 0;
  });

const statusLabel: Record<string, string> = {
  development: 'In development',
  stable: 'Stable',
  lts: 'Long-Term Support',
  legacy: 'Legacy',
  eol: 'End of life',
};

// Resolve tool entries referenced by this version
type ToolRow = {
  slug: string;
  toolName: string;
  toolRole: string;
  toolRoles: ('archaeologist' | 'modeller' | 'developer')[];
  toolDocs: string | undefined;
  toolRepo: string | undefined;          // ← GitHub link from tool collection entry
  toolPage: string;
  version: string | undefined;
  // action — verb for the primary CTA pill. See schema in
  // src/content/config.ts. The Status column was retired in the
  // 2026-06-30 audit (every row was "included" in practice); the
  // visual hierarchy is now driven by the action verb instead.
  action: 'download' | 'install' | 'open';
  downloadUrl: string | undefined;
  downloadHref: string | undefined;     // base-prefixed for internal paths
  downloadIsExternal: boolean;
  note: string | undefined;
};

const toolRows: ToolRow[] = [];
for (const t of version.data.tools) {
  const entry = await getEntry('tools', t.slug);
  const rawDl = t.downloadUrl ?? entry?.data.downloadUrl;
  // Root-relative paths (e.g. "/tools/em-tools/#download") point at on-site
  // landing pages — prefix the base so the link resolves under the
  // /ExtendedMatrix-site/ preview path AND on the bare production domain.
  const isExternal = !!rawDl && /^(https?:|mailto:|tel:)/i.test(rawDl);
  const downloadHref = !rawDl
    ? undefined
    : isExternal
      ? rawDl
      : `${B}${rawDl}`;
  toolRows.push({
    slug: t.slug,
    toolName: entry?.data.name ?? t.slug,
    toolRole: entry?.data.role ?? '',
    toolRoles: entry?.data.roles ?? [],
    toolDocs: entry?.data.docsUrl,
    toolRepo: entry?.data.repoUrl,
    toolPage: `${B}/tools/${t.slug}/`,
    version: t.version,
    action: t.action,
    downloadUrl: rawDl,
    downloadHref,
    downloadIsExternal: isExternal,
    note: t.note,
  });
}

// Verb metadata for the CTA pill. Keyed by ToolRow.action.
const ctaLabel: { download: string; install: string; open: string } = {
  download: 'Download ↓',
  install:  'Install →',
  open:     'Open ↗',
};
---

<BaseLayout
  title={`EM ${version.data.version}`}
  description={version.data.summary}
>
  <article class="vp">
    <div class="container">
      <a href={`${B}/versions/`} class="vp__back">← All versions</a>

      <!--
        Version switcher — chip strip with every release so the user
        can jump between adjacent versions in one click. The active
        chip is highlighted; the rest are passive links. Aligned left
        like the breadcrumb above to read as a navigation row rather
        than a content block.
      -->
      <nav class="vp__switcher" aria-label="Switch EM version">
        <span class="vp__switcher-label">Version:</span>
        <ul class="vp__switcher-list">
          {versionChips.map((vc) => (
            <li>
              {vc.slug === versionSlug
                ? <span class={`vp__chip vp__chip--active vp__chip--${vc.status}`} aria-current="page">EM {vc.label}</span>
                : <a class={`vp__chip vp__chip--${vc.status}`} href={`${B}/versions/${vc.slug}/`}
                     data-goatcounter-click={`vp-switch-${vc.slug}`}>EM {vc.label}</a>}
            </li>
          ))}
        </ul>
      </nav>

      <!--
        Double title dropped (2026-07-01). The previous layout showed
        "EM 1.5" (small) + "LONG-TERM SUPPORT" pill on one row, then
        the full "EM 1.5 — Long-Term Support" H1 immediately below —
        three signals for one fact (the version chip strip above
        already codes the status via its border variant). Merged: the
        status pill sits inline with the H1, the small number row is
        gone.
      -->
      <h1 class="vp__title">
        {version.data.title}
        <span class={`vp__status vp__status--inline v__status--${version.data.status}`}>{statusLabel[version.data.status]}</span>
      </h1>
      <p class="vp__lede">{version.data.summary}</p>

      <!-- ── Compatibility table ─────────────────────────────── -->
      <section class="vp__compat">
        <h2>Compatibility</h2>
        <dl class="vp__dl">
          {version.data.releaseDate && (
            <>
              <dt>Released</dt>
              <dd>{version.data.releaseDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</dd>
            </>
          )}
          {version.data.eolDate && (
            <>
              <dt>Supported until</dt>
              <dd>{version.data.eolDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}</dd>
            </>
          )}
          {version.data.blenderMin && (
            <>
              <dt>Blender</dt>
              <dd>
                {version.data.blenderLts
                  ? <><strong>{version.data.blenderLts} LTS</strong> (pinned)</>
                  : <>{version.data.blenderMin}+</>}
                {version.data.blenderTested.length > 0 && (
                  <span class="vp__tested"> · tested on {version.data.blenderTested.join(', ')}</span>
                )}
                {version.data.blenderPinNote && (
                  <details class="vp__pin-details">
                    <summary>What this pin means (ABI · Mac Intel · LTS plan)</summary>
                    <div class="vp__pin-body" set:html={
                      version.data.blenderPinNote
                        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
                        .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
                    } />
                  </details>
                )}
              </dd>
            </>
          )}
          <dt>yEd</dt>
          <dd>{version.data.yedRequirement}</dd>
          {version.data.supersededBy && (
            <>
              <dt>Superseded by</dt>
              <dd><a href={`${B}/versions/${version.data.supersededBy.replace('.', '-')}/`}>EM {version.data.supersededBy}</a></dd>
            </>
          )}
        </dl>
      </section>

      <!-- ── Core formal language ──────────────────────────────
           Moved to the top of the version content (above the
           Prerequisites block) on 2026-06-30 so the page leads
           with "EM is a language" before naming the third-party
           software that helps you USE the language. Mentioning
           Blender immediately under the version number used to
           make EM look like a Blender-only add-on, which is
           the wrong first impression.
      -->
      <section class="vp__lang">
        <div class="vp__lang-head">
          <h2>Core language — EM {version.data.version}</h2>
          <span class="vp__lang-tag">formal language</span>
        </div>
        <p class="vp__lang-lede">
          The formal language is the heart of the release. Everything else
          in the framework — tools, exports, web platforms — exists to
          author, manage and publish what is described below.
        </p>
        {version.data.languageFeatures.length > 0 && (
          <ul class="vp__features">
            {version.data.languageFeatures.map((f) => (
              <li>{f}</li>
            ))}
          </ul>
        )}
        <div class="vp__lang-links">
          {version.data.docsUrl && (
            <a href={version.data.docsUrl} target="_blank" rel="noopener" class="vp__btn">
              Language manual ↗
            </a>
          )}
          {version.data.changelogUrl && (
            <a href={version.data.changelogUrl} target="_blank" rel="noopener" class="vp__btn vp__btn--ghost">
              Changelog ↗
            </a>
          )}
          {version.data.paletteUrl && (
            <a href={version.data.paletteUrl} target="_blank" rel="noopener" class="vp__btn vp__btn--ghost">
              Palette repo ↗
            </a>
          )}
          {version.data.languagePaperUrl && !version.data.flagPaper && (
            <a href={version.data.languagePaperUrl} target="_blank" rel="noopener" class="vp__btn vp__btn--ghost">
              Reference paper ↗
            </a>
          )}
        </div>

        {version.data.flagPaper && (
          <div class={`vp__flag${version.data.flagPaper.isFoundation ? ' vp__flag--foundation' : ''}`}>
            <div class="vp__flag-head">
              <span class="vp__flag-tag">
                {version.data.flagPaper.isFoundation ? 'Foundation paper' : 'Flag paper'}
              </span>
              {version.data.flagPaper.doi && (
                <span class="vp__flag-doi">DOI: {version.data.flagPaper.doi}</span>
              )}
            </div>
            <p class="vp__flag-cite">
              <strong>{version.data.flagPaper.authors}</strong> ({version.data.flagPaper.year}).
              <em>{version.data.flagPaper.title}</em>
              {version.data.flagPaper.venue && <>. {version.data.flagPaper.venue}</>}.
            </p>
            {version.data.flagPaper.note && (
              <p class="vp__flag-note" set:html={
                version.data.flagPaper.note.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2">$1</a>')
              } />
            )}
            <div class="vp__flag-actions">
              {version.data.flagPaper.url && (
                <a href={version.data.flagPaper.url} target="_blank" rel="noopener" class="vp__btn">
                  Open paper ↗
                </a>
              )}
              <a href={`${B}/cite/`} class="vp__btn vp__btn--ghost">
                How to cite EM →
              </a>
            </div>
          </div>
        )}
      </section>

      <!-- ── Prerequisites ─────────────────────────────────────
           Lives BELOW the language section so the page reads as
           "EM is this formal language" → "and here are the
           third-party software packages that help you author and
           publish it". The reverse order made EM look like a
           Blender plugin by mention-priority, which it isn't.
      -->
      <section class="vp__prereq">
        <h2>Prerequisites</h2>
        <p class="vp__prereq-lede">
          The Extended Matrix language is the heart of the project, but to
          author and publish a project on your computer you also need a
          few free, third-party tools alongside the EM-specific ones in
          the next section. Install them once and they apply to every EM
          project.
        </p>
        <div class="vp__prereq-grid">
          <a class="prereq" href={version.data.blenderDownloadUrl ?? 'https://www.blender.org/download/'} target="_blank" rel="noopener"
             data-goatcounter-click={`dl-blender-${versionSlug}`}>
            <div class="prereq__name">Blender</div>
            <div class="prereq__ver">
              {version.data.blenderLts ? `${version.data.blenderLts} LTS` : `${version.data.blenderMin}+`}
            </div>
            <div class="prereq__desc">3D authoring environment. Free, GPL-3.</div>
            <span class="prereq__cta">Download from blender.org ↗</span>
          </a>
          <a class="prereq" href={version.data.yedDownloadUrl} target="_blank" rel="noopener"
             data-goatcounter-click={`dl-yed-${versionSlug}`}>
            <div class="prereq__name">yEd</div>
            <div class="prereq__ver">{version.data.yedRequirement}</div>
            <div class="prereq__desc">Free graph editor used to author the EM `.graphml` file.</div>
            <span class="prereq__cta">Download from yworks.com ↗</span>
          </a>
        </div>
      </section>

      <!-- ── Tools by role cluster ─────────────────────────────
           The flat tools table used to be daunting for first-time
           visitors: 8-10 entries with no editorial guidance about
           which to download first. Replaced with three role-bound
           clusters that mirror the /start triad (archaeologist /
           modeller / developer) plus a "starred" marker on the
           Core items every project needs regardless of role
           (palette, source list, folder tree). Each cluster is its
           own visually distinct box; tools appear in their PRIMARY
           role cluster (first entry of the `roles` array), with
           role-badges still visible so multi-role tools are
           discoverable from any angle. Cross-ref to Find Your Path
           at the bottom of the section.
      -->
      {toolRows.length > 0 && (() => {
        // Group tools by primary role (first entry of t.toolRoles).
        // Tools without any role fall into a fourth "Other" bucket
        // at the bottom — present here only as a safety net.
        const CORE_SLUGS = new Set(['yed-palette', 'source-list-xlsx', 'folder-tree']);
        // NB on the syntax used here: the Astro template parser
        // (inside this `{(() => { ... })()}` expression) mistakes
        // TypeScript generic-prefix forms (Record-of-comma,
        // Array-of-brace, etc.) for JSX tag opens and fails the
        // build with cascading parse errors. So this block uses
        // object literals instead of Record generics, and an
        // explicit switch instead of a generic-cast lookup. Same
        // end-state for the TS checker, zero parser ambiguity.
        const buckets: {
          core: typeof toolRows;
          archaeologist: typeof toolRows;
          modeller: typeof toolRows;
          developer: typeof toolRows;
          other: typeof toolRows;
        } = {
          core: [],
          archaeologist: [],
          modeller: [],
          developer: [],
          other: [],
        };
        // Multi-role tools (EM Tools = archaeologist+modeller,
        // Heriverse = archaeologist+modeller+developer, …) appear in
        // EVERY cluster they belong to rather than only their first
        // role. This avoids the misleading visual asymmetry where a
        // tool with role-badges shown ([archaeologist, modeller]) is
        // physically present in only one of the two clusters. Host
        // editorial decision (2026-06-30): tags > containers when a
        // tool genuinely spans roles.
        //
        // Core items (palette, source-list, folder-tree) are the
        // foundation every project needs regardless of role. They
        // get extracted into a dedicated "Core" cluster at the top
        // (decision 2026-06-30) and skipped from the per-role
        // buckets so they don't double-render. Without this, the
        // palette would land inside "For archaeologists" — true but
        // misleading, since modellers and developers also need it.
        for (const t of toolRows) {
          if (CORE_SLUGS.has(t.slug)) {
            buckets.core.push(t);
            continue;
          }
          const roles = (t.toolRoles && t.toolRoles.length > 0)
            ? t.toolRoles
            : ['other'];
          for (const r of roles) {
            switch (r) {
              case 'archaeologist': buckets.archaeologist.push(t); break;
              case 'modeller':      buckets.modeller.push(t);      break;
              case 'developer':     buckets.developer.push(t);     break;
              default:              buckets.other.push(t);
            }
          }
        }
        // Cluster metadata (label, lede, modifier class for styling).
        // Type uses the postfix-array form to avoid the Astro parser
        // ambiguity (see comment above).
        const clusters: { key: keyof typeof buckets; label: string; lede: string; mod: string }[] = [
          {
            key: 'core',
            label: 'Core · for everyone',
            lede: 'The foundation every EM project needs, regardless of whether you intend to model in 3D, develop on top of the graph, or simply read the matrix on paper. Start here, then add the role-specific clusters below as the work calls for them.',
            mod: 'core',
          },
          {
            key: 'archaeologist',
            label: 'For archaeologists',
            lede: 'Adds the archaeologist-facing tools on top of Core: graph authoring in Blender, stratigraphic database integrations, source dossier management.',
            mod: 'archaeologist',
          },
          {
            key: 'modeller',
            label: 'For 3D modellers',
            lede: 'Reach for these once your matrix is in good shape and you need to attach proxies to a photogrammetric model or run a survey pipeline.',
            mod: 'modeller',
          },
          {
            key: 'developer',
            label: 'For developers',
            lede: 'Lower-level libraries and tooling for anyone extending Extended Matrix or building integrations.',
            mod: 'developer',
          },
        ];

        // Row-CTA renderer — replaces the previous 6-column matrix
        // (2026-06-30 audit). Each tool becomes a single horizontal
        // row with:
        //   • left block — name + optional role + version chip + note
        //   • right block — primary action pill (Download/Install/
        //     Open, label driven by `action`) + small Manual chip +
        //     GitHub icon
        // Reads as a checklist of CTAs rather than a data table.
        // Status column dropped entirely (it was always "included").
        const renderRow = (t: typeof toolRows[number]) => {
          const isCore = CORE_SLUGS.has(t.slug);
          return (
            <li class={isCore ? 'vp__cta-row vp__cta-row--core' : 'vp__cta-row'}>
              <div class="vp__cta-meta">
                <div class="vp__cta-name">
                  <a href={t.toolPage}>
                    {isCore && (
                      <span class="vp__star" aria-label="Core item — recommended for every project">★</span>
                    )}
                    <strong>{t.toolName}</strong>
                  </a>
                  {t.version && (
                    <span class="vp__cta-ver" title={`Version paired with EM ${version.data.version}`}>v{t.version}</span>
                  )}
                </div>
                {t.note && <div class="vp__cta-note" set:html={
                  t.note
                    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
                    .replace(/`(.+?)`/g, '<code>$1</code>')
                    .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
                } />}
              </div>
              <div class="vp__cta-actions">
                {t.downloadHref && (
                  <a href={t.downloadHref}
                     class={`vp__cta-btn vp__cta-btn--${t.action}`}
                     target={t.downloadIsExternal ? '_blank' : undefined}
                     rel={t.downloadIsExternal ? 'noopener' : undefined}
                     data-goatcounter-click={`dl-${t.slug}-${versionSlug}`}>
                    {ctaLabel[t.action]}
                  </a>
                )}
                {t.toolDocs && t.toolDocs !== t.downloadHref && (
                  <a href={t.toolDocs} target="_blank" rel="noopener" class="vp__cta-chip"
                     title={`${t.toolName} manual`}>manual ↗</a>
                )}
                {t.toolRepo && (
                  <a href={t.toolRepo} target="_blank" rel="noopener"
                     class="vp__cta-icon"
                     aria-label={`${t.toolName} source code on GitHub`}
                     title="Source code on GitHub"
                     data-goatcounter-click={`repo-${t.slug}-${versionSlug}`}>
                    <svg viewBox="0 0 24 24" width="18" height="18"
                         fill="currentColor" aria-hidden="true">
                      <path d="M12 .5C5.4.5 0 5.9 0 12.5c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.4-1.3-5.4-5.9 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.3 3 .1 3.3.8.9 1.3 2 1.3 3.2 0 4.6-2.7 5.6-5.4 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.8-1.6 8.2-6.2 8.2-11.4C24 5.9 18.6.5 12 .5z"/>
                    </svg>
                  </a>
                )}
              </div>
            </li>
          );
        };

        return (
          <section class="vp__tools">
            <h2>Tools shipping with this version</h2>
            <p class="vp__tools-intro">
              <strong>If you're new to EM</strong>, start with the
              <strong>Core · for everyone</strong> cluster — these
              three items are the foundation every project needs,
              regardless of role. Then pick up the archaeologist,
              modeller or developer clusters only when the work
              calls for them.
            </p>
            {clusters.map((c) => buckets[c.key].length > 0 && (
              <section class={`vp__cluster vp__cluster--${c.mod}`}>
                <header class="vp__cluster-head">
                  <span class={`vp__cluster-tag vp__cluster-tag--${c.mod}`}>{c.label}</span>
                </header>
                <p class="vp__cluster-lede">{c.lede}</p>
                <ul class="vp__cta-list">{buckets[c.key].map(renderRow)}</ul>
              </section>
            ))}
            {buckets.other.length > 0 && (
              <section class="vp__cluster vp__cluster--other">
                <header class="vp__cluster-head">
                  <span class="vp__cluster-tag vp__cluster-tag--other">Other</span>
                </header>
                <ul class="vp__cta-list">{buckets.other.map(renderRow)}</ul>
              </section>
            )}

            <!--
              Cross-ref to Find Your Path — the other half of the
              decision loop. Find Your Path picks tools by what
              the user wants to do; this page picks them by which
              version they want to pin to. The two surfaces feed
              each other.
            -->
            <aside class="vp__not-sure">
              <h3>Not sure which tools you need?</h3>
              <p>
                Walk through <a href={`${B}/find-your-path/`}>Find your path</a> —
                pick the materials you already have and the outcome you want, and
                the picker maps the project to the right combination of EM
                language artefacts and tools. Then come back here for the right
                version of each.
              </p>
            </aside>
          </section>
        );
      })()}

      <!--
        Install card removed from the version page (2026-06-30).
        Previously this block embedded the BlenderRepoInstall
        component on each version (channel=dev for development lines,
        channel=stable for LTS / stable lines). Host editorial
        decision: the drag-and-drop install belongs on the per-tool
        page (/tools/em-tools/), not duplicated on every version
        page. Symmetric with 3DSC, whose install card has always
        lived only on /tools/3dsc/. The version page now relies on
        the components-table row's "download" link, which routes
        to the appropriate per-tool install anchor.
      -->

      <!-- ── Install steps ───────────────────────────────────── -->
      {version.data.installSteps.length > 0 && (
        <section class="vp__install">
          <h2>Installation</h2>
          <p class="vp__install-lede">
            Step-by-step installation of Extended Matrix {version.data.version}.
          </p>
          <ol class="vp__steps">
            {version.data.installSteps.map((s) => (
              <li set:html={s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\*(.+?)\*/g, '<em>$1</em>').replace(/`(.+?)`/g, '<code>$1</code>')} />
            ))}
          </ol>
        </section>
      )}

      <!--
        "Quick links for this release" block REMOVED (audit 2026-06-30):
        every link it carried was already reachable above with more
        context — Language docs ↗ duplicates the button on the Core
        language box; Changelog ↗ likewise; the EM Tools releases link
        is already in the Code column of the EM Tools row in the Tools
        cluster. Keeping it amounted to "the page is finished, please
        read the same three links a third time" right before a
        substantial prose body.
      -->

      <!-- ── Body content ────────────────────────────────────── -->
      <section class="vp__body">
        <Content />
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .vp { padding: 60px 0 80px; }
  /*
   * Neutralise the site-wide `section { padding: 80px 0; }` rule
   * declared in `global.css` (intended for full-bleed marketing
   * sections like the homepage hero). On the version page every
   * inline `<section class="vp__*">` is a sub-block of a continuous
   * article; the 80px top + 80px bottom padding would stack with the
   * `.vp__* { margin-top }` rule below and produce ~200px gaps
   * between consecutive blocks. Reset to zero and let the per-block
   * margin-top drive the rhythm.
   */
  .vp section { padding: 0; }

  .vp__back { display: inline-block; font-size: 13px; color: var(--em-text-muted); margin-bottom: 16px; }

  /* Version switcher — chip strip just below the breadcrumb.
     Reads as navigation, not content: small label, inline list of
     chips, active chip highlighted. Wraps gracefully on narrow
     viewports. */
  .vp__switcher {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin: 4px 0 22px;
    font-size: 13px;
  }
  .vp__switcher-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--em-text-muted);
    font-weight: 700;
  }
  .vp__switcher-list {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .vp__chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 999px;
    border: 1px solid var(--em-border);
    background: var(--em-bg);
    color: var(--em-text);
    text-decoration: none;
    line-height: 1.5;
    transition: border-color 0.15s var(--ease), background 0.15s var(--ease);
  }
  .vp__chip:hover {
    border-color: var(--em-gold);
    text-decoration: none;
  }
  .vp__chip--active {
    background: var(--em-navy);
    color: #fff;
    border-color: var(--em-navy);
    cursor: default;
  }
  .vp__chip--active:hover { border-color: var(--em-navy); }
  /* Subtle status accent on the chips so the user spots LTS / dev
     lines at a glance. Active chip uses the navy fill regardless. */
  .vp__chip--lts:not(.vp__chip--active)         { border-color: var(--em-gold); }
  .vp__chip--development:not(.vp__chip--active) { border-color: var(--em-navy); border-style: dashed; }
  .vp__chip--legacy:not(.vp__chip--active)      { color: var(--em-text-muted); }
  .vp__chip--eol:not(.vp__chip--active)         { color: #a22; border-color: #fae0e0; }

  /* Status pill — retired as a standalone `.vp__head` row (2026-07-01)
     and now rendered INLINE next to the H1 title via .vp__status--inline.
     The `.vp__head` / `.vp__num` rules stay in place only in case a
     future page reintroduces the compact row; they are unused as of
     this commit. */
  .vp__status {
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    padding: 3px 10px; border-radius: 2px;
  }
  .vp__status--inline {
    display: inline-block;
    vertical-align: middle;
    margin-left: 14px;
    /* Optical alignment vs the H1 baseline — small nudge downward. */
    position: relative;
    top: -6px;
  }
  .v__status--lts        { color: var(--em-gold); background: var(--em-gold-tint); }
  .v__status--development{ color: var(--em-navy); background: var(--em-navy-tint); }
  .v__status--stable     { color: #2c5a2c; background: #d8ecd8; }
  .v__status--legacy     { color: #555;    background: #eee; }
  .v__status--eol        { color: #a22;    background: #fae0e0; }
  .vp__title { margin: 18px 0 16px; }
  .vp__lede { color: var(--em-text); font-size: 17px; max-width: 720px; margin-bottom: 28px; }

  .vp__compat, .vp__prereq, .vp__lang, .vp__tools, .vp__install, .vp__body { margin-top: 40px; }
  .vp__compat h2, .vp__prereq h2, .vp__lang h2, .vp__tools h2, .vp__install h2 { font-size: 22px; margin-bottom: 12px; }

  /* Core language */
  .vp__lang {
    background: linear-gradient(180deg, var(--em-gold-tint) 0%, var(--em-bg) 100%);
    border: 1px solid var(--em-gold);
    border-left-width: 4px;
    border-radius: var(--radius-md);
    /* Generous breathing room — bullets, title, tag pill and CTAs
       all need air around them. Bumped twice on host feedback. */
    padding: 40px 44px;
  }
  .vp__lang-head { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
  .vp__lang-head h2 { margin: 0; }
  .vp__lang-tag {
    font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--em-gold); background: rgba(255,255,255,0.6);
    padding: 3px 10px; border-radius: 2px; border: 1px solid var(--em-gold);
  }
  .vp__lang-lede { color: var(--em-text); margin: 12px 0 16px; max-width: 720px; line-height: 1.7; }
  .vp__features {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: grid;
    gap: 6px;
  }
  .vp__features li {
    position: relative;
    padding: 6px 0 6px 22px;
    font-size: 14px;
    color: var(--em-text);
    border-bottom: 1px dashed rgba(184, 137, 58, 0.3);
  }
  .vp__features li:last-child { border-bottom: none; }
  .vp__features li::before {
    content: '◆';
    position: absolute;
    left: 0;
    top: 6px;
    color: var(--em-gold);
    font-size: 11px;
  }
  .vp__lang-links { display: flex; gap: 12px; flex-wrap: wrap; }

  /* Flag paper block */
  .vp__flag {
    margin-top: 22px;
    padding: 18px 22px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--em-border);
    border-left: 4px solid var(--em-navy);
    border-radius: var(--radius-sm);
  }
  .vp__flag--foundation { border-left-color: var(--em-gold); background: var(--em-gold-tint); }
  .vp__flag-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .vp__flag-tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--em-navy);
    background: var(--em-navy-tint);
    padding: 3px 10px;
    border-radius: 2px;
  }
  .vp__flag--foundation .vp__flag-tag { color: var(--em-gold); background: rgba(255, 255, 255, 0.7); }
  .vp__flag-doi {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--em-text-muted);
  }
  .vp__flag-cite {
    font-size: 14px;
    color: var(--em-text);
    line-height: 1.6;
    margin: 0 0 8px;
  }
  .vp__flag-note {
    font-size: 13px;
    color: var(--em-text-muted);
    font-style: italic;
    line-height: 1.55;
    margin: 0 0 14px;
  }
  .vp__flag-note a { color: var(--em-gold); }
  .vp__flag-actions { display: flex; gap: 10px; flex-wrap: wrap; }

  .vp__dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 8px 24px;
    background: var(--em-bg-warm);
    padding: 18px 22px;
    border-radius: var(--radius-md);
    margin: 0;
  }
  .vp__dl dt { font-weight: 600; color: var(--em-text-muted); font-size: 13px; }
  .vp__dl dd { color: var(--em-text); font-size: 14px; margin: 0; }
  .vp__tested { color: var(--em-text-muted); font-size: 13px; }

  /* Collapsed disclosure for the Blender-pin lore. Lives inside the
     Compatibility table's <dd> so the table stays compact for users
     who don't need the ABI / Mac Intel / LTS-plan detail. */
  .vp__pin-details {
    margin-top: 6px;
    font-size: 13px;
  }
  .vp__pin-details > summary {
    cursor: pointer;
    color: var(--em-gold);
    font-weight: 600;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .vp__pin-details > summary::before {
    content: '▸';
    font-size: 10px;
    transition: transform 0.15s var(--ease);
  }
  .vp__pin-details[open] > summary::before { transform: rotate(90deg); }
  .vp__pin-details > summary::-webkit-details-marker { display: none; }
  .vp__pin-body {
    margin-top: 8px;
    padding: 10px 14px;
    background: var(--em-bg-warm);
    border-left: 3px solid var(--em-gold);
    border-radius: var(--radius-sm);
    line-height: 1.6;
    color: var(--em-text);
    max-width: 640px;
  }
  .vp__pin-body a { color: var(--em-navy); }

  /* Prerequisites */
  .vp__prereq-lede { color: var(--em-text-muted); margin-bottom: 16px; max-width: 720px; }
  .vp__prereq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .prereq {
    display: block;
    border: 1px solid var(--em-border);
    border-left: 3px solid var(--em-navy);
    border-radius: var(--radius-md);
    padding: 22px 24px;
    background: var(--em-bg);
    color: var(--em-text);
    transition: border-color 0.2s var(--ease);
  }
  .prereq:hover { border-color: var(--em-gold); text-decoration: none; }
  .prereq__name { font-family: var(--font-display); font-weight: 700; font-size: 18px; color: var(--em-navy); }
  .prereq__ver { font-family: var(--font-mono); font-size: 12px; color: var(--em-gold); margin: 2px 0 8px; }
  .prereq__desc { font-size: 13px; color: var(--em-text-muted); line-height: 1.5; margin-bottom: 10px; }
  .prereq__cta { color: var(--em-gold); font-weight: 600; font-size: 13px; }

  /* Tools — clustered by primary role.
     Each cluster is its own visual card with a left accent bar that
     codes the role family (gold / navy-tint / grey). The "Core"
     items inside the archaeologist cluster carry a ★ to flag them
     as "always needed regardless of role". */
  .vp__tools-intro {
    margin: 0 0 24px;
    max-width: 720px;
    padding: 14px 18px;
    background: var(--em-bg-warm);
    border-left: 3px solid var(--em-navy);
    border-radius: var(--radius-sm);
    font-size: 14px;
    line-height: 1.6;
    color: var(--em-text);
  }
  .vp__cluster {
    margin: 0 0 32px;
    /* Generous breathing room around the inner content. Previously
       the cluster-tag pill sat right against the top of the box and
       the table edges hit the side borders. */
    padding: 32px 36px;
    border: 1px solid var(--em-border);
    border-left-width: 4px;
    border-radius: var(--radius-md);
    background: var(--em-bg);
  }
  /* Core cluster — visually prioritised so it reads as "start here"
     before the role-coded clusters below. Uses the gold accent that
     used to live on archaeologist, since Core IS the foundation; the
     archaeologist cluster moves to a calmer navy accent to step
     visually behind it. */
  .vp__cluster--core {
    border-left-color: var(--em-gold);
    background: linear-gradient(180deg, var(--em-gold-tint) 0%, var(--em-bg) 30%);
    border-left-width: 6px;
  }
  .vp__cluster--archaeologist {
    border-left-color: var(--em-navy);
    background: linear-gradient(180deg, var(--em-navy-tint) 0%, var(--em-bg) 35%);
  }
  .vp__cluster--modeller {
    border-left-color: var(--em-navy);
    background: linear-gradient(180deg, var(--em-navy-tint) 0%, var(--em-bg) 35%);
  }
  .vp__cluster--developer {
    border-left-color: #666;
    background: var(--em-bg);
  }
  .vp__cluster--other {
    border-left-color: var(--em-border);
    background: var(--em-bg-warm);
  }

  .vp__cluster-head {
    /* More vertical breathing room between the cluster tag and the
       lede/list below (2026-07-01 padding pass). */
    margin-bottom: 20px;
  }
  .vp__cluster-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    /* Pill inner padding bumped from 4px/12px to 8px/16px so the
       cluster title (which is now longer — "Core · for everyone",
       "For archaeologists" etc) sits with proper air around it. */
    padding: 8px 16px;
    border-radius: 3px;
  }
  .vp__cluster-tag--core           { color: var(--em-navy); background: rgba(184, 137, 58, 0.22); }
  .vp__cluster-tag--archaeologist  { color: var(--em-navy); background: var(--em-navy-tint); }
  .vp__cluster-tag--modeller       { color: var(--em-navy); background: var(--em-navy-tint); }
  .vp__cluster-tag--developer      { color: #333;          background: #e8e8e8; }
  .vp__cluster-tag--other          { color: #666;          background: #f0f0ed; }

  .vp__cluster-lede {
    margin: 8px 0 18px;
    max-width: 700px;
    color: var(--em-text-muted);
    font-size: 14px;
    line-height: 1.6;
  }

  /* Star on the Core items inside the Core cluster. */
  .vp__star {
    display: inline-block;
    color: var(--em-gold);
    font-size: 14px;
    margin-right: 4px;
    vertical-align: baseline;
  }
  .vp__cta-row--core {
    /* Subtle gold tint to reinforce Core importance without competing
       with the cluster's own gold left-border accent. */
    background: rgba(184, 137, 58, 0.045);
  }

  /* "Not sure?" cross-ref to Find Your Path at the bottom of the tools
     section. Quieter than the cluster cards above so it reads as a
     pivot, not as another tool family. */
  .vp__not-sure {
    margin-top: 8px;
    padding: 18px 22px;
    background: var(--em-bg-warm);
    border: 1px dashed var(--em-border);
    border-radius: var(--radius-md);
  }
  .vp__not-sure h3 {
    margin: 0 0 6px;
    font-size: 16px;
    color: var(--em-navy);
  }
  .vp__not-sure p {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--em-text);
    max-width: 720px;
  }
  .vp__not-sure a {
    color: var(--em-navy);
    font-weight: 600;
  }
  .vp__not-sure a:hover { color: var(--em-gold); }

  /* Tools — row-CTA list (replaces the previous 6-column matrix on
     2026-06-30). Each tool is a horizontal row:
       • left  → name (+ optional version chip) + freeform note
       • right → primary action pill (Download/Install/Open),
                 secondary "manual ↗" chip, GitHub icon
     The visual hierarchy is action-first: the eye lands on the gold
     pill on the right, not on the column headers. No table headers
     because every row tells the same story; if the user needs to
     "see what the columns are" we have failed.

     Why a list, not a 2-column grid: grids stack their items into
     ~card chunks that scan as visual blocks rather than ordered
     steps. A list of rows reads as "Core download A, then B, then C
     — then move on to the archaeologist cluster, etc.", which is
     the editorial intent of the cluster sequence. */
  .vp__cta-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .vp__cta-row {
    display: flex;
    gap: 18px;
    align-items: center;
    padding: 14px 16px;
    border-bottom: 1px solid var(--em-border);
    transition: background 0.12s var(--ease);
  }
  .vp__cta-row:last-child { border-bottom: 0; }
  .vp__cta-row:hover { background: var(--em-bg-warm); }
  .vp__cta-meta {
    flex: 1 1 auto;
    min-width: 0; /* allow long URLs in notes to wrap instead of stretching the row */
  }
  .vp__cta-actions {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .vp__cta-name {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
  }
  .vp__cta-name a { color: var(--em-navy); }
  .vp__cta-name a:hover { color: var(--em-gold); }
  .vp__cta-name strong { font-size: 15px; }
  .vp__cta-ver {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--em-text-muted);
    background: var(--em-bg-warm);
    padding: 1px 6px;
    border-radius: 2px;
    border: 1px solid var(--em-border);
  }
  .vp__cta-note {
    margin-top: 4px;
    font-size: 12.5px;
    color: var(--em-text);
    line-height: 1.55;
    max-width: 640px;
  }
  .vp__cta-note code {
    font-family: var(--font-mono);
    font-size: 11.5px;
    background: var(--em-bg-warm);
    padding: 1px 4px;
    border-radius: 2px;
  }
  .vp__cta-note a { color: var(--em-navy); text-decoration: underline; }
  .vp__cta-note a:hover { color: var(--em-gold); }

  /* Primary CTA pill — the focal point of every row. */
  .vp__cta-btn {
    display: inline-block;
    padding: 7px 16px;
    font-weight: 700;
    font-size: 13px;
    border-radius: 999px;
    background: var(--em-gold);
    color: var(--em-bg) !important;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.12s var(--ease), transform 0.12s var(--ease);
  }
  .vp__cta-btn:hover {
    background: #a37828;
    text-decoration: none;
    transform: translateY(-1px);
  }
  /* Action-variant tinting — Download = full gold (default),
     Install = navy (signals "in-app flow"), Open = ghost gold
     (signals "go elsewhere, this isn't an install"). */
  .vp__cta-btn--install {
    background: var(--em-navy);
  }
  .vp__cta-btn--install:hover { background: #0e1a36; }
  .vp__cta-btn--open {
    background: transparent;
    color: var(--em-gold) !important;
    border: 1.5px solid var(--em-gold);
    padding: 5.5px 14.5px;
  }
  .vp__cta-btn--open:hover {
    background: var(--em-gold-tint);
    color: var(--em-gold) !important;
  }

  /* Manual chip — secondary action, muted. */
  .vp__cta-chip {
    display: inline-block;
    padding: 5px 10px;
    font-size: 12px;
    color: var(--em-navy);
    background: transparent;
    border: 1px solid var(--em-border);
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.12s var(--ease), color 0.12s var(--ease);
  }
  .vp__cta-chip:hover { border-color: var(--em-gold); color: var(--em-gold); text-decoration: none; }

  /* GitHub icon — tertiary, just identifies the source-code link. */
  .vp__cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--em-text-muted);
    width: 24px;
    height: 24px;
    border-radius: var(--radius-sm);
    transition: color 0.15s var(--ease), background 0.15s var(--ease);
  }
  .vp__cta-icon:hover {
    color: var(--em-gold);
    background: var(--em-gold-tint);
    text-decoration: none;
  }
  .vp__cta-icon svg { display: block; }

  /* Install steps */
  .vp__install-lede { color: var(--em-text-muted); margin-bottom: 16px; }
  .vp__steps {
    list-style: none;
    counter-reset: step;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 6px;
  }
  .vp__steps li {
    counter-increment: step;
    position: relative;
    padding: 14px 18px 14px 56px;
    background: var(--em-bg-warm);
    border: 1px solid var(--em-border);
    border-radius: var(--radius-sm);
    line-height: 1.55;
    color: var(--em-text);
  }
  .vp__steps li::before {
    content: counter(step);
    position: absolute;
    left: 14px;
    top: 12px;
    width: 28px;
    height: 28px;
    background: var(--em-navy);
    color: var(--em-bg);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
  }
  .vp__steps li code {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--em-navy-tint);
    color: var(--em-navy);
    padding: 1px 6px;
    border-radius: 2px;
  }

  /* Buttons */
  .vp__btn {
    background: var(--em-navy);
    color: var(--em-bg);
    padding: 12px 20px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 14px;
    transition: background 0.2s var(--ease);
  }
  .vp__btn:hover { background: var(--em-gold); color: var(--em-bg); text-decoration: none; }
  .vp__btn--ghost { background: transparent; color: var(--em-navy); border: 1px solid var(--em-navy); }
  .vp__btn--ghost:hover { background: var(--em-navy); color: var(--em-bg); }

  .vp__body :global(h2) { margin-top: 32px; font-size: 22px; }
  .vp__body :global(h3) { margin-top: 24px; font-size: 18px; }
  .vp__body :global(p) { margin-bottom: 14px; line-height: 1.7; }
  .vp__body :global(ul), .vp__body :global(ol) { margin-bottom: 14px; padding-left: 22px; }
  .vp__body :global(table) { width: 100%; border-collapse: collapse; margin: 12px 0 18px; font-size: 14px; }
  .vp__body :global(th), .vp__body :global(td) { padding: 8px 12px; border-bottom: 1px solid var(--em-border); text-align: left; }
  .vp__body :global(blockquote) {
    border-left: 3px solid var(--em-gold);
    padding: 8px 16px;
    color: var(--em-text-muted);
    font-style: italic;
    margin: 16px 0;
  }

  /* ── Inline figure / image-ready placeholder ───────────────
     Used by version body markdown via:
       <figure class="emfig" data-slot="...">
         <img src="..." alt="..." /><figcaption>...</figcaption>
       </figure>
     and
       <figure class="emfig emfig--placeholder" data-slot="..."
               data-aspect="16x9|4x3|hero">
         <div class="emfig__box">
           <span class="emfig__label">image to add</span>
           <span class="emfig__alt">…alt text…</span>
         </div>
         <figcaption>…caption…</figcaption>
       </figure>
     The placeholder is meant to be visible in the rendered page so
     editors can spot the slots that still need real images. */
  .vp__body :global(.emfig) {
    margin: 24px 0;
    display: block;
  }
  .vp__body :global(.emfig img) {
    display: block;
    width: 100%;
