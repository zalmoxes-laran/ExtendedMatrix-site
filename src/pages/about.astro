---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const partners = (await getCollection('partners'))
  .sort((a, b) => a.data.order - b.data.order);

const groupOrder: Record<string, number> = {
  'eu-project': 1,
  'national-project': 2,
  'research-institute': 3,
  'university': 4,
  'cultural-institution': 5,
  'company': 6,
};
const grouped: Record<string, typeof partners> = {};
for (const p of partners) {
  const k = p.data.kind;
  (grouped[k] ??= []).push(p);
}
const groupKeys = Object.keys(grouped).sort(
  (a, b) => (groupOrder[a] ?? 99) - (groupOrder[b] ?? 99)
);
const B = import.meta.env.BASE_URL.replace(/\/$/, '');
const groupLabel: Record<string, string> = {
  'eu-project': 'European projects',
  'national-project': 'National projects',
  'research-institute': 'Research institutes',
  'university': 'Universities',
  'cultural-institution': 'Cultural institutions',
  'company': 'Companies',
};
---

<BaseLayout
  title="About"
  description="Extended Matrix — what it is, where it comes from, who maintains it, and how to cite it."
>
  <section class="about">
    <div class="container">
      <span class="tag">About</span>
      <h1>Extended Matrix in one page.</h1>

      <div class="about__grid">
        <div>
          <h2>What it is</h2>
          <p>
            <strong>Extended Matrix (EM)</strong> is a formal language for
            documenting stratigraphy and virtual reconstruction processes
            in cultural heritage. It is a typed, graphical notation —
            stratigraphic units, sources, paradata, connectors — that
            archaeologists and heritage specialists can read, write and
            review by hand, and that machines can process at scale through
            the <a href={`${B}/tools/s3dgraphy/`}><code>s3dgraphy</code></a> Python library.
          </p>
          <p>
            The project was started in 2015 around the reconstruction of
            the Great Temple of Sarmizegetusa and has since been adopted in
            dozens of research and professional projects. Extended Matrix is
            being developed (2025–2029) within the
            <strong>StratiGraph</strong> project, part of the
            <a href="https://www.eccch.eu" target="_blank" rel="noopener">European Collaborative Cloud for Cultural Heritage (ECCCH)</a>.
          </p>

          <h2>Lead</h2>
          <p>
            EM is led by <strong>Emanuel Demetrescu</strong> at
            <a href="https://www.ispc.cnr.it" target="_blank" rel="noopener">CNR-ISPC</a>
            (Institute for Heritage Science, National Research Council of Italy,
            Rome — formerly CNR-ITABC).
          </p>

          <h2>Citation</h2>
          <p>
            EM uses a <strong>cumulative citation rule</strong>: always cite
            the 2015 foundation paper, then add the flag paper of the EM
            version you actually used (and a software DOI when relevant).
            The full guidance and BibTeX entries live on the dedicated
            <a href={`${B}/cite/`}><strong>How to cite EM</strong></a> page.
          </p>
          <p>
            For the canonical bibliography and glossary of formal terms,
            see the
            <a href="https://docs.extendedmatrix.org/en/latest/references.html" target="_blank" rel="noopener">References</a>
            and
            <a href="https://docs.extendedmatrix.org/en/latest/glossary.html" target="_blank" rel="noopener">Glossary</a>
            pages of the language documentation.
          </p>
          <p class="about__cite-quick">Software DOI for quick reference:</p>
          <pre class="cite" is:raw>@misc{demetrescu_extendedmatrix,
  title     = {Extended Matrix},
  author    = {Demetrescu, Emanuel},
  publisher = {Zenodo},
  doi       = {10.5281/zenodo.5957132},
  url       = {https://doi.org/10.5281/zenodo.5957132}
}</pre>

          <h2>Licence</h2>
          <p>
            <strong>Software.</strong> All EM software components — the
            <a href={`${B}/tools/s3dgraphy/`}>s3dgraphy</a> library,
            <a href={`${B}/tools/em-tools/`}>EM Tools</a>,
            <a href={`${B}/tools/3dsc/`}>3DSC</a>,
            <a href={`${B}/tools/heriverse/`}>Heriverse</a> — are released
            under <strong>GPL-3.0-or-later</strong>. See the individual
            repositories on
            <a href="https://github.com/topics/extended-matrix" target="_blank" rel="noopener">GitHub</a>
            for the exact licence files.
          </p>
          <p>
            <strong>Site content.</strong> The editorial content of this
            website — text, screenshots, diagrams — is released under
            <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener">CC BY-NC 4.0</a>.
            Reuse is welcome for teaching, research and non-commercial
            remixing, with attribution. For commercial use, write to
            <a href="mailto:emanuel.demetrescu@cnr.it">emanuel.demetrescu@cnr.it</a>.
            Third-party logos in <code>src/assets/logos/</code> belong to
            their respective owners and are used by permission.
          </p>
          <p>
            <strong>Datasets.</strong> Examples, paradata bundles and
            case studies deposited on the
            <a href="https://zenodo.org/communities/extendedmatrix" target="_blank" rel="noopener">Zenodo community</a>
            carry their own licence, chosen by each contributor.
          </p>

          <h2>Privacy</h2>
          <p>
            extendedmatrix.org is a static informational site for a
            public-research project. We do not run analytics, do not set
            tracking cookies, and do not log visitors beyond what GitHub
            does at the infrastructure level. A small number of pages
            embed third-party content (YouTube, Zenodo). Full details and
            your GDPR rights are listed on the
            <a href={`${B}/privacy`}><strong>privacy notice</strong></a>.
          </p>
        </div>

        <aside>
          <h2>EM and EMF, in one paragraph</h2>
          <p class="aside__lede">
            <strong>EM</strong> is the formal language — a typed graphical
            notation that can be drawn with pencil and paper, no software
            required. <strong>EMF (EM Framework)</strong> is the digital
            toolset that lets you author, manage and publish EM at scale:
            it includes <strong><a href={`${B}/tools/yed-palette/`}>yEd</a></strong> (graph editor),
            <strong><a href={`${B}/tools/s3dgraphy/`}>s3dgraphy</a></strong> (Python library), <strong><a href={`${B}/tools/em-tools/`}>EM Tools</a></strong>
            (Blender add-on), <strong><a href={`${B}/tools/3dsc/`}>3DSC</a></strong> (photogrammetry
            pipeline), <strong><a href={`${B}/tools/heriverse/`}>Heriverse</a></strong> (web platform), and a
            growing set of connectors and extensions.
          </p>

          <h2>Quick links</h2>
          <ul class="links">
            <li><a href={`${B}/start`}>→ Start here</a></li>
            <li><a href={`${B}/cite`}>→ How to cite EM</a></li>
            <li><a href={`${B}/projects`}>→ Projects</a></li>
            <li><a href={`${B}/community`}>→ Community &amp; meetings</a></li>
            <li><a href="https://docs.extendedmatrix.org" target="_blank" rel="noopener">→ Language docs</a></li>
            <li><a href="https://docs.extendedmatrix.org/projects/EM-tools/" target="_blank" rel="noopener">→ EM Tools manual</a></li>
            <li><a href="https://docs.extendedmatrix.org/projects/heriverse/en/latest/" target="_blank" rel="noopener">→ Heriverse</a></li>
            <li><a href="https://github.com/topics/extended-matrix" target="_blank" rel="noopener">→ GitHub</a></li>
            <li><a href="https://zenodo.org/communities/extendedmatrix" target="_blank" rel="noopener">→ Zenodo community</a></li>
          </ul>
        </aside>
      </div>

      <!-- ── Partners section ───────────────────────────────────── -->
      <section class="partners">
        <h2>Funding, partners, contributors</h2>
        <p class="partners__lede">
          Extended Matrix is developed at CNR-ISPC and is supported by
          European and national funding programmes, and by an active
          community of contributors across universities and research
          institutes.
        </p>

        {groupKeys.map((k) => (
          <div class="partner-group">
            <h3>{groupLabel[k] ?? k}</h3>
            <ul class="partner-list">
              {grouped[k].map((p) => {
                const inner = (
                  <>
                    {p.data.logo && (
                      <img
                        src={p.data.logo.src}
                        alt={p.data.logoAlt || p.data.name}
                        class="partner__logo"
                        loading="lazy"
                      />
                    )}
                    <div class="partner__body">
                      <div class="partner__main">
                        <span class="partner__name">{p.data.name}</span>
                        {p.data.country && <span class="partner__country">{p.data.country}</span>}
                        {p.data.timeline && <span class="partner__timeline">{p.data.timeline}</span>}
                      </div>
                      {p.data.note && <div class="partner__note">{p.data.note}</div>}
                    </div>
                    <span class={`partner__rel partner__rel--${p.data.relation}`}>{p.data.relation}</span>
                  </>
                );
                return (
                  <li class={`partner ${p.data.logo ? 'partner--with-logo' : ''}`}>
                    {p.data.url ? (
                      <a href={p.data.url} target="_blank" rel="noopener">{inner}</a>
                    ) : (
                      <div>{inner}</div>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        ))}

        <p class="partners__foot">
          <em>If your institution uses EM and is not listed here, open a
          PR on
          <a href="https://github.com/zalmoxes-laran/ExtendedMatrix-site" target="_blank" rel="noopener">ExtendedMatrix-site</a>
          adding a YAML file in <code>src/content/partners/</code> — see
          the <a href="https://github.com/zalmoxes-laran/ExtendedMatrix-site/blob/main/EDITORS_GUIDE.md" target="_blank" rel="noopener">EDITORS_GUIDE</a>.</em>
        </p>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .about { padding: 80px 0 60px; }
  .about h1 { margin: 14px 0 36px; }
  .about__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    margin-bottom: 80px;
  }
  .about h2 {
    font-size: 22px;
    margin: 28px 0 12px;
  }
  .about h2:first-child { margin-top: 0; }
  .about p { margin-bottom: 14px; }
  .about code {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--em-navy-tint);
    color: var(--em-navy);
    padding: 1px 6px;
    border-radius: 2px;
  }
  .cite {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--em-bg-warm);
    border: 1px solid var(--em-border);
    padding: 16px 18px;
    border-radius: var(--radius-md);
    overflow-x: auto;
    color: var(--em-text);
  }
  aside {
    background: var(--em-bg-warm);
    border: 1px solid var(--em-border);
    border-radius: var(--radius-md);
    padding: 28px 28px 24px;
    height: max-content;
    position: sticky;
    top: 80px;
  }
  aside h2 { font-size: 15px !important; text-transform: uppercase; letter-spacing: 0.06em; color: var(--em-gold); margin-top: 22px; }
  aside h2:first-child { margin-top: 0; }
  .aside__lede { font-size: 14px; line-height: 1.65; }
  .links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 6px;
  }
  .links a {
    display: block;
    padding: 4px 0;
    font-size: 14px;
    color: var(--em-navy);
  }
  .links a:hover { color: var(--em-gold); text-decoration: none; }

  .partners { margin-top: 64px; }
  .partners h2 { font-size: 28px; margin-bottom: 12px; }
  .partners__lede {
    color: var(--em-text-muted);
    max-width: 720px;
    margin-bottom: 40px;
  }
  .partner-group { margin-bottom: 32px; }
  .partner-group h3 {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--em-gold);
    margin-bottom: 12px;
  }
  .partner-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 10px;
  }
  .partner {
    border: 1px solid var(--em-border);
    border-radius: var(--radius-sm);
    background: var(--em-bg);
    transition: border-color 0.2s var(--ease);
  }
  .partner:hover { border-color: var(--em-gold); }
  .partner > a, .partner > div {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    color: inherit;
  }
  .partner > a { text-decoration: none; }
  .partner > a:hover { text-decoration: none; }
  .partner > a:hover .partner__name { color: var(--em-gold); }
  .partner__logo {
    width: 56px;
    height: 56px;
    object-fit: contain;
    flex-shrink: 0;
    background: var(--em-bg);
    border-radius: 2px;
  }
  .partner__body { display: flex; flex-direction: column; gap: 4px; flex: 1; min-width: 0; }
  .partner__main { display: flex; align-items: center; flex-wrap: wrap; gap: 4px 10px; }
  .partner__name { font-weight: 600; color: var(--em-navy); transition: color 0.2s var(--ease); }
  .partner__country {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--em-text-muted);
  }
  .partner__timeline {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--em-gold);
    background: var(--em-gold-tint);
    padding: 1px 7px;
    border-radius: 2px;
    letter-spacing: 0.02em;
  }
  .partner__note {
    font-size: 12px;
    color: var(--em-text-muted);
    line-height: 1.45;
    font-style: italic;
  }
  .partner__rel {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--em-text-muted);
    background: var(--em-bg-warm);
    padding: 2px 8px;
    border-radius: 2px;
    margin-left: auto;
    align-self: flex-start;
    white-space: nowrap;
    flex-shrink: 0;
  }
  /* Distinctive accents for richer relation kinds. The default styling
     above stays for `uses`, `contributes` and `collaborates`. */
  .partner__rel--funds {
    color: var(--em-gold);
    background: var(--em-gold-tint);
    border: 1px solid var(--em-gold);
  }
  .partner__rel--orchestrates {
    color: var(--em-bg);
    background: var(--em-navy);
    border: 1px solid var(--em-navy);
  }
  .partners__foot {
    margin-top: 40px;
    color: var(--em-text-muted);
    font-size: 13px;
  }

  @media (max-width: 800px) {
    .about__grid { grid-template-columns: 1fr; gap: 32px; }
    aside { position: static; }
  }
</style>
