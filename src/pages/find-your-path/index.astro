/* Phase metadata */
const phases = [
  { num: 1, title: 'Data Collection' },
  { num: 2, title: 'Data Management & Analysis' },
  { num: 3, title: 'Implementation & Virtual Reconstruction' },
  { num: 4, title: 'Representation Model' },
  { num: 5, title: 'Publication & Dissemination' }
];

/* =====================================================================
   STATE
===================================================================== */
const state = {
  step: 1,
  materials: new Set(),
  goals: new Set(),
  ecosystemMode: false
};

/* Root element where the focus-mode class lives. */
const rootEl = document.querySelector('.find-your-path');

/* =====================================================================
   COMPOSITION LOGIC
===================================================================== */
function activeBlocks(materialsSet, goalsSet) {
  const active = new Set();
  for (const [id, block] of Object.entries(blockCatalog)) {
    if (block.triggers && block.triggers.always) { active.add(id); continue; }
    const triggers = block.triggers || {};
    if (triggers.materials && triggers.materials.some(m => materialsSet.has(m))) {
      active.add(id);
      continue;
    }
    if (triggers.goals && triggers.goals.some(g => goalsSet.has(g))) {
      active.add(id);
      continue;
    }
  }
  return active;
}

/* =====================================================================
   STEP 1 / 2 RENDERERS
===================================================================== */
function renderSelectableGrid(container, items, selectedSet, onChange, kind) {
  container.innerHTML = '';
  items.forEach(item => {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'card' + (item.status === 'in-development' ? ' card--in-dev' : '');
    btn.setAttribute('aria-pressed', selectedSet.has(item.id) ? 'true' : 'false');
    btn.dataset.id = item.id;
    /* GoatCounter annotation */
    btn.setAttribute('data-goatcounter-click', 'picker_' + kind + '_' + item.id);
    if (item.status === 'in-development') {
      btn.title = 'Coming soon — currently in development';
    }
    const iconHtml = item.iconSvg
      ? ICONS[item.iconSvg]
      : (item.icon || '•');
    const comingBadge = item.status === 'in-development'
      ? ` <span class="badge-coming">in dev</span>`
      : '';
    btn.innerHTML = `
      <span class="card__icon">${iconHtml}</span>
      <span class="card__title">${item.title}${comingBadge}</span>
      <span class="card__desc">${item.desc}</span>
    `;
    btn.addEventListener('click', () => {
      if (selectedSet.has(item.id)) selectedSet.delete(item.id);
      else selectedSet.add(item.id);
      btn.setAttribute('aria-pressed', selectedSet.has(item.id) ? 'true' : 'false');
      onChange();
    });
    container.appendChild(btn);
  });
}

function updateStep1Controls() {
  const count = state.materials.size;
  const el = document.getElementById('materialsCount');
  if (el) el.textContent = count === 0 ? 'Pick at least one' : `${count} selected`;
  const btn = document.getElementById('toStep2');
  if (btn) btn.disabled = count === 0;
}

function updateStep2Controls() {
  const count = state.goals.size;
  const el = document.getElementById('goalsCount');
  if (el) el.textContent = count === 0 ? 'Pick at least one' : `${count} selected`;
  const btn = document.getElementById('toStep3');
  if (btn) btn.disabled = count === 0;
}

/* =====================================================================
   STEP 3 RENDERER — 5-step backbone
===================================================================== */
function renderBackbone() {
  const active = activeBlocks(state.materials, state.goals);

  /* Summary chips */
  const sum = document.getElementById('schemaSummary');
  const matChips = [...state.materials].map(id => {
    const m = materials.find(x => x.id === id);
    if (!m) return '';
    const inDev = m.status === 'in-development';
    return `<span class="chip${inDev ? ' chip--in-dev' : ''}">${m.title}${inDev ? ' (in dev)' : ''}</span>`;
  }).join('');
  const goalChips = [...state.goals].map(id => {
    const g = goals.find(x => x.id === id);
    return g ? `<span class="chip chip--goal">${g.title}</span>` : '';
  }).join('');
  sum.innerHTML = `
    <strong>Your inputs:</strong>
    <span class="schema-summary__chips">${matChips || '<span class="chip">(none)</span>'}</span>
    &nbsp;·&nbsp;
    <strong>Goals:</strong>
    <span class="schema-summary__chips">${goalChips || '<span class="chip">(none)</span>'}</span>
  `;

  /* Phase tracks */
  const tracks = document.getElementById('backboneTracks');
  tracks.innerHTML = '';

  /* Inter-phase arrows: gold if at least one active stable block on either side */
  const arrowRow = document.getElementById('phaseArrowRow');
  if (arrowRow) {
    const arrows = arrowRow.querySelectorAll('.arrow');
    arrows.forEach((arr, i) => {
      const fromPhase = i + 1;
      const toPhase = i + 2;
      const hasActive = Object.entries(blockCatalog).some(([id, b]) =>
        (b.phase === fromPhase || b.phase === toPhase) &&
        active.has(id) && b.status !== 'in-development'
      );
      arr.classList.toggle('arrow--active', hasActive);
    });
  }

  phases.forEach(phase => {
    const col = document.createElement('div');
    col.className = 'phase-col';
    const inner = document.createElement('div');
    inner.className = 'phase-col__inner';

    const phaseBlocks = Object.entries(blockCatalog).filter(([, b]) => b.phase === phase.num);

    /* Sort: spine first, then active, then inactive, then in-dev */
    phaseBlocks.sort((a, b) => {
      const ba = a[1], bb = b[1];
      const score = (block, id) => {
        if (block.isSpine) return 0;
        if (active.has(id) && block.status !== 'in-development') return 1;
        if (block.status === 'in-development' && active.has(id)) return 2;
        if (block.status === 'in-development') return 4;
        return 3;
      };
      return score(ba, a[0]) - score(bb, b[0]);
    });

    let visibleCount = 0;

    phaseBlocks.forEach(([id, block]) => {
      const isActive = active.has(id);
      const isSpine = !!block.isSpine;
      const isInDev = block.status === 'in-development';

      const blockEl = document.createElement('button');
      blockEl.type = 'button';
      blockEl.className = 'block';
      blockEl.dataset.id = id;

      if (isSpine) blockEl.classList.add('is-spine');
      else if (isActive) blockEl.classList.add('is-active');
      else blockEl.classList.add('is-inactive');

      if (isInDev) blockEl.classList.add('is-in-dev');

      const hiddenInFocus = !isSpine && !isActive;
      if (!hiddenInFocus || state.ecosystemMode) visibleCount++;

      const linksHtml = buildPopLinks(block, id);
      const payloadHtml = block.payloadTabs
        ? `<div class="pop-payload">
            <strong>Payload options</strong>
            ${block.payloadTabs.map(t => `
              <div class="pop-payload-item">
                <span class="pi-label">${t.label}.</span>
                <span class="pi-desc">${t.desc}</span>
              </div>
            `).join('')}
          </div>`
        : '';
      const advancedHtml = block.advancedNote
        ? `<p><em>Advanced:</em> ${block.advancedNote}${
            block.advancedLink ? ` <a href="${block.advancedLink.url}" target="_blank" rel="noopener" data-goatcounter-click="picker_outbound_manual_${id}_advanced">${block.advancedLink.label}</a>` : ''
          }</p>`
        : '';

      blockEl.innerHTML = `
        <span class="block__title">${block.title}</span>
        <span class="block__tool">${block.tool}</span>
        <div class="block__pop">
          <strong>${block.title}</strong>
          <p>${block.microcopy}</p>
          ${advancedHtml}
          ${payloadHtml}
          <div class="pop-links">${linksHtml}</div>
        </div>
      `;
      inner.appendChild(blockEl);
    });

    if (phaseBlocks.length === 0 || (visibleCount === 0 && !state.ecosystemMode)) {
      inner.classList.add('phase-col__inner--empty');
      inner.innerHTML = `<span>(nothing in your path here — toggle the ecosystem view to see options)</span>`;
    }

    col.appendChild(inner);
    tracks.appendChild(col);
  });
}

function buildPopLinks(block, id) {
  const parts = [];
  const isInDev = block.status === 'in-development';
  if (block.learnLink) {
    parts.push(`<a href="${withBase(block.learnLink.url)}" target="_blank" rel="noopener" data-goatcounter-click="picker_outbound_manual_${id}">${block.learnLink.label}</a>`);
  } else if (!isInDev) {
    parts.push(`<span class="tutorial-coming">Documentation coming</span>`);
  }
  if (block.howToLink) {
    parts.push(`<a href="${withBase(block.howToLink.url)}" target="_blank" rel="noopener" data-goatcounter-click="picker_outbound_manual_${id}_howto">${block.howToLink.label}</a>`);
  } else if (!isInDev) {
    parts.push(`<span class="tutorial-coming">Tutorial coming</span>`);
  }
  if (block.getLink) {
    parts.push(`<a href="${withBase(block.getLink.url)}" target="_blank" rel="noopener" data-goatcounter-click="picker_outbound_tool_${id}">${block.getLink.label}</a>`);
  } else if (!isInDev) {
    parts.push(`<span class="tutorial-coming">Tool info coming</span>`);
  }
  return parts.join('');
}

/* =====================================================================
   FOCUS / ECOSYSTEM TOGGLE
===================================================================== */
function applyMode() {
  if (rootEl) rootEl.classList.toggle('focus-mode', !state.ecosystemMode);
  const stateLabel = document.getElementById('modeToggleState');
  if (stateLabel) {
    stateLabel.textContent = state.ecosystemMode ? 'ecosystem view' : 'focus mode';
  }
  if (state.step === 3) renderBackbone();
}

/* =====================================================================
   STEP NAVIGATION
===================================================================== */
function goToStep(n) {
  state.step = n;

  ['step1', 'step2', 'step3'].forEach((id, idx) => {
    const el = document.getElementById(id);
    if (el) el.classList.toggle('step--hidden', (idx + 1) !== n);
  });

  const dots = [document.getElementById('dot1'), document.getElementById('dot2'), document.getElementById('dot3')];
  const bars = [document.getElementById('bar1'), document.getElementById('bar2')];
  const label = document.getElementById('progressLabel');

  dots.forEach(d => d && d.classList.remove('progress__dot--active', 'progress__dot--done'));
  bars.forEach(b => b && b.classList.remove('progress__bar--done'));

  if (n >= 1 && dots[0]) dots[0].classList.add(n > 1 ? 'progress__dot--done' : 'progress__dot--active');
  if (n >= 2) { if (dots[1]) dots[1].classList.add(n > 2 ? 'progress__dot--done' : 'progress__dot--active'); if (bars[0]) bars[0].classList.add('progress__bar--done'); }
  if (n >= 3) { if (dots[2]) dots[2].classList.add('progress__dot--active'); if (bars[1]) bars[1].classList.add('progress__bar--done'); }

  if (label) label.textContent = ['Step 1 of 3 · What you have', 'Step 2 of 3 · What you want', 'Step 3 of 3 · Your path'][n - 1];

  if (n === 3) renderBackbone();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

/* =====================================================================
   URL PARAM HANDLING
===================================================================== */
function loadFromUrl() {
  const params = new URLSearchParams(window.location.search);
  const validMaterialIds = new Set(materials.map(m => m.id));
  const validGoalIds = new Set(goals.map(g => g.id));

  const matStr = params.get('materials');
  if (matStr) {
    matStr.split(',').map(s => s.trim()).forEach(id => {
      if (validMaterialIds.has(id)) state.materials.add(id);
    });
  }
  const goalStr = params.get('goals');
  if (goalStr) {
    goalStr.split(',').map(s => s.trim()).forEach(id => {
      if (validGoalIds.has(id)) state.goals.add(id);
    });
  }

  /* If both groups have at least one valid entry, jump to Step 3.
     If only materials, jump to Step 2.
     Otherwise stay on Step 1. */
  if (state.materials.size > 0 && state.goals.size > 0) return 3;
  if (state.materials.size > 0) return 2;
  return 1;
}

function buildShareUrl() {
  const url = new URL(window.location.href);
  url.search = '';
  if (state.materials.size > 0) url.searchParams.set('materials', [...state.materials].join(','));
  if (state.goals.size > 0) url.searchParams.set('goals', [...state.goals].join(','));
  return url.toString();
}

function copyShareLink() {
  const url = buildShareUrl();
  const feedback = document.getElementById('copyFeedback');
  const finish = (msg) => {
    if (feedback) {
      feedback.textContent = msg;
      setTimeout(() => { feedback.textContent = ''; }, 2400);
    }
  };
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(url).then(
      () => finish('Link copied to clipboard ✓'),
      () => fallbackCopy(url, finish)
    );
  } else {
    fallbackCopy(url, finish);
  }
}

function fallbackCopy(text, finish) {
  try {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed';
    ta.style.opacity = '0';
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    finish('Link copied to clipboard ✓');
  } catch (e) {
    finish('Could not copy. URL: ' + text);
  }
}

/* =====================================================================
   BOOT
===================================================================== */
function boot() {
  const stableMaterials = materials.filter(m => m.status !== 'in-development');
  const inDevMaterials  = materials.filter(m => m.status === 'in-development');

  renderSelectableGrid(document.getElementById('materialsGridStable'), stableMaterials, state.materials, updateStep1Controls, 'material');
  renderSelectableGrid(document.getElementById('materialsGridInDev'),  inDevMaterials,  state.materials, updateStep1Controls, 'material');
  renderSelectableGrid(document.getElementById('goalsGrid'),           goals,           state.goals,     updateStep2Controls, 'goal');
  updateStep1Controls();
  updateStep2Controls();

  const t2 = document.getElementById('toStep2'); if (t2) t2.addEventListener('click', () => goToStep(2));
  const t3 = document.getElementById('toStep3'); if (t3) t3.addEventListener('click', () => goToStep(3));
  const b1 = document.getElementById('backTo1'); if (b1) b1.addEventListener('click', () => goToStep(1));
  const b2 = document.getElementById('backTo2'); if (b2) b2.addEventListener('click', () => goToStep(2));
  const cl = document.getElementById('copyLink'); if (cl) cl.addEventListener('click', copyShareLink);
  const rs = document.getElementById('restart'); if (rs) rs.addEventListener('click', () => {
    state.materials.clear();
    state.goals.clear();
    /* Clear URL params too */
    const url = new URL(window.location.href);
    url.search = '';
    window.history.replaceState({}, '', url.toString());
    boot();
    goToStep(1);
  });

  const toggleInput = document.getElementById('modeToggleInput');
  if (toggleInput) {
    toggleInput.checked = state.ecosystemMode;
    toggleInput.addEventListener('change', (e) => {
      state.ecosystemMode = !!e.target.checked;
      applyMode();
    });
  }

  applyMode();

  /* Apply URL params on first boot */
  if (!boot._initialised) {
    boot._initialised = true;
    const startStep = loadFromUrl();
    if (startStep > 1) goToStep(startStep);
  }
}

boot();
</script>
