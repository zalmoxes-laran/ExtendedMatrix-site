---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Extended Matrix — a formal language for transparent archaeological reconstruction.',
  ogImage,
} = Astro.props;

const fullTitle = title === 'Extended Matrix'
  ? 'Extended Matrix'
  : `${title} — Extended Matrix`;

const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${B}/favicon.svg`} />
    <link rel="canonical" href={Astro.url.toString()} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.toString()} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!--
      Fonts are self-hosted under /public/fonts/. No connection is ever made
      to fonts.googleapis.com or fonts.gstatic.com — visitor IPs are never
      transferred to Google. The @font-face declarations are emitted inline
      below so the URLs can resolve the GitHub Pages BASE_URL correctly.
      Both Inter and Manrope are variable fonts: a single woff2 per subset
      serves every weight we use (400/500/600/700/800).
    -->
    <link rel="preload" href={`${B}/fonts/inter/inter-latin.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${B}/fonts/manrope/manrope-latin.woff2`} as="font" type="font/woff2" crossorigin />
    <style is:inline set:html={`
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
        src: url('${B}/fonts/inter/inter-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
        src: url('${B}/fonts/inter/inter-latin-ext.woff2') format('woff2');
        unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
      }
      @font-face {
        font-family: 'Manrope';
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
        src: url('${B}/fonts/manrope/manrope-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Manrope';
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
        src: url('${B}/fonts/manrope/manrope-latin-ext.woff2') format('woff2');
        unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
      }
    `}></style>

    <!--
      GoatCounter analytics — cookieless, EU-hosted (Netherlands), GDPR-friendly, free.
      Account: emanueldemetrescu.goatcounter.com (registered to emanuel.demetrescu@cnr.it).
      Tracks page views and (via data-goatcounter-click annotations) download counts.
      Site is registered for extendedmatrix.org; GoatCounter accepts hits from any
      host — the DNS flip in early June 2026 required no script change.

      The inline auto-annotation script below runs on DOMContentLoaded, walks all
      outbound anchors, and stamps a `data-goatcounter-click` attribute on
      anything that looks like a release / download / info link to a canonical
      host (GitHub, PyPI, Zenodo, our own docs / dev tracker). Manually-annotated
      links are preserved as-is. This catches Markdown-rendered links inside
      content collections that can't get the attribute at author-time.
    -->
    <script is:inline
            data-goatcounter="https://emanueldemetrescu.goatcounter.com/count"
            async src="//gc.zgo.at/count.js"></script>
    <script is:inline>
      (function () {
        function slug(s) {
          return String(s).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
        }
        function classify(href) {
          // Returns a goatcounter event id for known outbound destinations,
          // or null when the link should be left alone (internal / unclassified).
          var url;
          try { url = new URL(href, location.href); } catch (e) { return null; }
          var h = url.hostname.replace(/^www\./, '');
          var p = url.pathname;

          // GitHub: distinguish releases / raw / blob / repo-root.
          if (h === 'github.com') {
            var parts = p.split('/').filter(Boolean);
            if (parts.length < 2) return null;
            var owner = parts[0], repo = parts[1];
            if (parts[2] === 'releases') return 'repo-release-' + slug(owner + '-' + repo);
            if (parts[2] === 'raw' || parts[2] === 'blob') {
              var fname = parts[parts.length - 1].replace(/\.(zip|xlsx|graphml|whl|tar\.gz|pdf|json|yaml|yml)$/i, '');
              return 'dl-raw-' + slug(owner + '-' + repo + '-' + fname);
            }
            if (parts[2] === 'issues' || parts[2] === 'pulls') return 'repo-issues-' + slug(owner + '-' + repo);
            // bare repo or branch link
            return 'repo-' + slug(owner + '-' + repo);
          }

          // PyPI
          if (h === 'pypi.org') {
            var m = p.match(/^\/project\/([^\/]+)/);
            if (m) return 'dl-pypi-' + slug(m[1]);
            return null;
          }

          // Zenodo: community vs record vs raw file.
          if (h === 'zenodo.org') {
            if (/^\/communities\//.test(p)) {
              var m2 = p.match(/^\/communities\/([^\/]+)/);
              return 'info-zenodo-' + slug(m2 ? m2[1] : 'community');
            }
            if (/^\/records?\//.test(p) || /^\/api\/files\//.test(p)) {
              var m3 = p.match(/\/(records?|files)\/([^\/]+)/);
              return 'dl-zenodo-' + slug(m3 ? m3[2] : 'record');
            }
            return 'info-zenodo';
          }

          // Our own docs (RTD-hosted).
          if (h === 'docs.extendedmatrix.org') {
            var dp = p.replace(/^\/+|\/+$/g, '').split('/').slice(0, 4).join('-');
            return 'info-docs-' + (slug(dp) || 'root');
          }

          // Dev tracker.
          if (h === 'dev.extendedmatrix.org') {
            var dpath = p.replace(/^\/+|\/+$/g, '');
            return 'info-dev-tracker' + (dpath ? '-' + slug(dpath) : '');
          }

          // Direct file extensions on any other host (rare but worth catching).
          var ext = (p.match(/\.([a-z0-9]{2,5})(?:[?#]|$)/i) || [])[1];
          if (ext && /^(zip|xlsx|graphml|whl|tar|pdf|csv|json)$/i.test(ext)) {
            return 'dl-file-' + slug(h + '-' + p.split('/').pop());
          }

          // Blender / yEd download pages — typically reached via the picker
          // which already adds an explicit event, but Markdown links elsewhere
          // would slip through.
          if (h === 'blender.org' && /\/download/.test(p)) return 'info-blender-download';
          if (h === 'yworks.com' && /yed/.test(p)) return 'info-yed-download';

          return null;
        }

        function annotate() {
          var anchors = document.querySelectorAll('a[href]');
          for (var i = 0; i < anchors.length; i++) {
            var a = anchors[i];
            if (a.hasAttribute('data-goatcounter-click')) continue;
            var href = a.getAttribute('href') || '';
            if (!href || href[0] === '#' || /^javascript:/i.test(href) || /^mailto:/i.test(href)) continue;
            var id = classify(href);
            if (id) a.setAttribute('data-goatcounter-click', id);
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', annotate, { once: true });
        } else {
          annotate();
        }
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
